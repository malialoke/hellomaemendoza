</section>

<!-- CTA -->
<section class="cta-section" data-section="7">
  <div class="reveal">
    <div class="section-num">The Takeaway</div>
    <h2 class="section-title">The content problem<br>was really a <em style="font-family:'DM Serif Display',serif;color:var(--accent)">systems problem.</em></h2>
    <p class="cta-sub">Two failing products. Fifty sets of regional requirements. One modular architecture that turned a catalog liability into a scalable framework.</p>
    <div class="footer-meta">Mae Mendoza &mdash; Content Design &times; Product Localization</div>
  </div>
</section>

</main>

<!-- D3 + TopoJSON -->

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/topojson/3.0.2/topojson.min.js"></script>

<script is:inline>
// ========== Theme Toggle (3-state: dark → light → rainbow) ==========
const toggle = document.getElementById('themeToggle');
const html = document.documentElement;
const themeOrder = ['dark', 'light', 'rainbow'];

toggle.addEventListener('click', () => {
  const current = html.dataset.theme || 'dark';
  const idx = themeOrder.indexOf(current);
  const next = themeOrder[(idx + 1) % themeOrder.length];
  html.dataset.theme = next;
  try { localStorage.setItem('mae-theme', next); } catch(e) {}
});
toggle.addEventListener('keydown', e => {
  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle.click(); }
});
// Theme defaults to whatever data-theme is set on <html>. Toggle saves preference for the session.

// ========== Reveal on Scroll ==========
const rObs = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) e.target.classList.add('visible');
}), { threshold: .12, rootMargin: '0px 0px -30px 0px' });
document.querySelectorAll('.reveal').forEach(el => rObs.observe(el));

// ========== Nav Dots ==========
const sections = document.querySelectorAll('section[data-section]');
const dotsC = document.getElementById('navDots');
sections.forEach((_, i) => {
  const d = document.createElement('button');
  d.className = 'nav-dot';
  d.setAttribute('aria-label', 'Go to section ' + (i + 1));
  d.addEventListener('click', () => sections[i].scrollIntoView({ behavior: 'smooth' }));
  dotsC.appendChild(d);
});
const dots = dotsC.querySelectorAll('.nav-dot');
const sObs = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) {
    const i = parseInt(e.target.dataset.section);
    dots.forEach((d, j) => d.classList.toggle('active', j === i));
  }
}), { threshold: .35 });
sections.forEach(s => sObs.observe(s));

// ========== Keyboard support for flip cards ==========
document.querySelectorAll('.flash-card, .dual-flip').forEach(card => {
  card.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
  });
});

// ========== Tier Data ==========
// Tier colors read from CSS variables at runtime
const getTC = () => {
  const s = getComputedStyle(document.documentElement);
  return {
    A: s.getPropertyValue('--tier-a').trim(),
    B: s.getPropertyValue('--tier-b').trim(),
    C: s.getPropertyValue('--tier-c').trim(),
    D: s.getPropertyValue('--tier-d').trim(),
    E: s.getPropertyValue('--tier-e').trim()
  };
};

const tiers = {
  Arkansas:'A',Florida:'A',Georgia:'A',Hawaii:'A',Indiana:'A',Iowa:'A',Louisiana:'A',
  Minnesota:'A',Mississippi:'A','North Dakota':'A',Ohio:'A',Oklahoma:'A',
  'South Carolina':'A',Tennessee:'A',Texas:'A',Utah:'A',Virginia:'A','West Virginia':'A',
  Alabama:'B',Alaska:'B',California:'B',Colorado:'B',Illinois:'B',Kentucky:'B',
  Michigan:'B',Montana:'B',Nebraska:'B','New Hampshire':'B','New York':'B',
  Oregon:'B','Rhode Island':'B','South Dakota':'B',Washington:'B',Wisconsin:'B',
  Arizona:'C',Connecticut:'C',Delaware:'C',Kansas:'C',Nevada:'C','New Mexico':'C',
  Pennsylvania:'C',Vermont:'C',Wyoming:'C',
  Maine:'D',Maryland:'D','New Jersey':'D','North Carolina':'D',
  Idaho:'E',Massachusetts:'E',Missouri:'E'
};

const tierInfo = {
  A: { label: 'Full Coverage', desc: 'Content addresses 90–100% of regional requirements.' },
  B: { label: 'Strong Coverage', desc: 'Broad coverage, minor structural gaps.' },
  C: { label: 'Moderate Coverage', desc: 'Majority covered, multiple domain gaps.' },
  D: { label: 'Limited Coverage', desc: 'Content thin or incidental in this region.' },
  E: { label: 'Minimal / None', desc: 'No relevant requirements or near-zero coverage.' }
};

const tierData = {
  a: { title: 'Full Coverage (18 states)', desc: 'Content addresses 90–100% of regional requirements.', states: 'AR, FL, GA, HI, IN, IA, LA, MN, MS, ND, OH, OK, SC, TN, TX, UT, VA, WV' },
  b: { title: 'Strong Coverage (16 states)', desc: 'Broad coverage with minor gaps. May need light supplementation in 1–2 areas.', states: 'AL, AK, CA, CO, IL, KY, MI, MT, NE, NH, NY, OR, RI, SD, WA, WI' },
  c: { title: 'Moderate Coverage (9 states)', desc: 'Content covers majority of requirements but has multiple domain gaps. Viable with caveats.', states: 'AZ, CT, DE, KS, NV, NM, PA, VT, WY' },
  d: { title: 'Limited Coverage (4 states)', desc: 'Content is thin or incidental. Product exceeds regional requirements.', states: 'ME, MD, NJ, NC' },
  e: { title: 'Minimal Coverage (3 states)', desc: 'No relevant requirements or no assessable content.', states: 'ID, MA, MO' }
};

// ========== Coverage Map ==========
const mapContainer = document.getElementById('coverageMap');
const mapSvg = d3.select('#coverageMap').append('svg')
  .attr('viewBox', '0 0 975 610')
  .attr('width', '100%')
  .attr('role', 'img')
  .attr('aria-label', 'US map showing content coverage tiers by region');

const mapTooltip = d3.select('#mapTooltip');

// Function to paint map with current theme colors
let statePaths;
function paintMap() {
  const tc = getTC();
  if (statePaths) {
    statePaths.attr('fill', d => {
      const t = tiers[d.properties.name];
      return t ? tc[t] : '#555';
    });
  }
}

d3.json('https://cdn.jsdelivr.net/npm/us-atlas@3/states-albers-10m.json').then(us => {
  statePaths = mapSvg.selectAll('path')
    .data(topojson.feature(us, us.objects.states).features)
    .join('path')
    .attr('class', 'state')
    .attr('d', d3.geoPath())
    .attr('stroke', 'var(--map-stroke)')
    .attr('stroke-width', 1.25)
    .attr('vector-effect', 'non-scaling-stroke')
    .attr('fill', d => {
      const tc = getTC();
      const t = tiers[d.properties.name];
      return t ? tc[t] : '#555';
    })
    .on('mouseenter', (e, d) => {
      const tc = getTC();
      const n = d.properties.name, t = tiers[n] || '?', info = tierInfo[t] || {};
      mapTooltip.style('display', 'block');
      mapTooltip.select('.mt-name').text(n);
      mapTooltip.select('.mt-tier').text(info.label || '').style('color', tc[t] || '#888');
      mapTooltip.select('.mt-desc').text(info.desc || '');
    })
    .on('mousemove', e => {
      const rect = mapContainer.getBoundingClientRect();
      mapTooltip.style('left', (e.clientX - rect.left + 14) + 'px')
        .style('top', (e.clientY - rect.top - 30) + 'px');
    })
    .on('mouseleave', () => mapTooltip.style('display', 'none'));

  // State borders
  mapSvg.append('path')
    .datum(topojson.mesh(us, us.objects.states, (a, b) => a !== b))
    .attr('fill', 'none')
    .attr('stroke', 'var(--map-stroke)')
    .attr('stroke-width', 1.25)
    .attr('d', d3.geoPath());
});

// Repaint map on theme change
const themeObs = new MutationObserver(() => paintMap());
themeObs.observe(html, { attributes: true, attributeFilter: ['data-theme'] });

// ========== Tier Bar Popover ==========
const pop = document.getElementById('tierPopover');
let activeTier = null;
document.querySelectorAll('.tier-segment').forEach(seg => {
  const handler = e => {
    e.stopPropagation();
    const t = seg.dataset.tier;
    if (activeTier === t) { closeTierPop(); return; }
    activeTier = t;
    const d = tierData[t];
    document.getElementById('tierPopTitle').textContent = d.title;
    document.getElementById('tierPopDesc').textContent = d.desc;
    document.getElementById('tierPopStates').textContent = d.states;
    pop.classList.add('show');
  };
  seg.addEventListener('click', handler);
  seg.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handler(e); }
  });
});
function closeTierPop() { pop.classList.remove('show'); activeTier = null; }
document.addEventListener('click', e => {
  if (!pop.contains(e.target) && !e.target.closest('.tier-segment')) closeTierPop();
});
</script>
</BaseLayout>
