---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Training Deck — Mae Mendoza" skipTarget="#slide-0" defaultTheme="dark">
<style is:inline>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

:root{
  --bg-primary:#0A1628;
  --bg-secondary:#0F2039;
  --bg-card:rgba(15,32,57,0.6);
  --bg-glass:rgba(255,255,255,0.04);
  --text-primary:#fff;
  --text-body:#D4DCE4;
  --text-muted:#8B9DB0;
  --border-subtle:rgba(255,255,255,0.06);
  --border-hover:rgba(255,255,255,0.14);
  --teal:#00B1AB;
  --teal-dim:rgba(0,177,171,0.15);
  --teal-glow:rgba(0,177,171,0.35);
  --orange:#F6A41A;
  --orange-dim:rgba(246,164,26,0.15);
  --pink:#EC0C6D;
  --pink-dim:rgba(236,12,109,0.1);
  --sky:#B8DFF0;
  --grain-opacity:0.03;
  --shadow-card:0 2px 16px rgba(0,0,0,0.2);
}

*{margin:0;padding:0;box-sizing:border-box}
html{font-size:18px}
body{font-family:'Outfit',sans-serif;background:var(--bg-primary);color:var(--text-body);overflow:hidden !important;-webkit-font-smoothing:antialiased;line-height:1.65;height:100vh !important}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");opacity:var(--grain-opacity);pointer-events:none;z-index:9999}

/* ========== CHROME ========== */
.back-link{position:fixed;top:24px;left:24px;z-index:200;font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;padding:8px 14px;border-radius:30px;background:var(--bg-card);backdrop-filter:blur(16px);border:1px solid var(--border-subtle);transition:all .3s}
.back-link:hover{color:var(--teal);border-color:var(--border-hover)}
.back-link:focus-visible{outline:2px solid var(--teal);outline-offset:2px}
.sample-label{position:fixed;top:24px;right:24px;z-index:200;font-family:'JetBrains Mono',monospace;font-size:.56rem;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);opacity:.5;padding:8px 14px;border-radius:30px;background:var(--bg-card);backdrop-filter:blur(16px);border:1px solid var(--border-subtle)}

/* ========== DECK VIEWPORT ========== */
.deck-viewport{position:relative;width:100%;height:100vh;overflow:hidden}
.deck-track{display:flex;height:100%;transition:transform .5s cubic-bezier(0.22,1,0.36,1)}
.slide{min-width:100vw;height:100vh;display:flex;flex-direction:column;justify-content:center;padding:80px clamp(48px,10vw,160px);position:relative;overflow-y:auto}

/* ========== SLIDE TYPOGRAPHY ========== */
.slide-eyebrow{font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--teal);margin-bottom:20px}
.slide h2{font-family:'DM Serif Display',serif;font-size:clamp(1.8rem,3.5vw,2.6rem);color:var(--text-primary);line-height:1.18;max-width:720px;margin-bottom:20px}
.slide h2 em{font-style:italic;color:var(--teal)}
.slide-lead{font-size:clamp(1rem,1.3vw,1.1rem);color:var(--text-muted);max-width:580px;line-height:1.7;font-weight:300;margin-bottom:32px}

/* ========== SLIDE: TITLE ========== */
.slide-title-page{background:radial-gradient(ellipse 80% 60% at 70% 40%,rgba(0,177,171,0.08) 0%,transparent 70%),radial-gradient(ellipse 50% 50% at 20% 80%,rgba(236,12,109,0.04) 0%,transparent 60%),var(--bg-primary)}
.slide-title-page h1{font-family:'DM Serif Display',serif;font-size:clamp(2.4rem,5vw,4rem);line-height:1.1;color:var(--text-primary);max-width:700px;margin-bottom:24px}
.slide-title-page h1 em{font-style:italic;color:var(--teal)}
.slide-title-sub{font-size:clamp(1rem,1.4vw,1.15rem);font-weight:300;color:var(--text-muted);max-width:540px;line-height:1.7;margin-bottom:40px}
.slide-meta{display:flex;gap:24px;flex-wrap:wrap}
.slide-meta span{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;color:var(--text-muted)}

/* ========== DATA CARDS ========== */
.tier-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:760px}
.tier-card{padding:20px 22px;border-radius:10px;background:var(--bg-card);border:1px solid var(--border-subtle);box-shadow:var(--shadow-card);border-left:3px solid var(--teal)}
.tier-card.critical{border-left-color:var(--pink)}
.tier-card.high{border-left-color:var(--orange)}
.tier-card.standard{border-left-color:var(--teal)}
.tier-card.public{border-left-color:var(--text-muted)}
.tier-card .tc-label{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;margin-bottom:6px}
.tier-card.critical .tc-label{color:var(--pink)}
.tier-card.high .tc-label{color:var(--orange)}
.tier-card.standard .tc-label{color:var(--teal)}
.tier-card.public .tc-label{color:var(--text-muted)}
.tier-card h4{font-weight:600;font-size:.9rem;color:var(--text-primary);margin-bottom:4px}
.tier-card p{font-size:.82rem;color:var(--text-muted);line-height:1.55}

/* ========== RESPONSE TABLE ========== */
.response-table{max-width:760px;border:1px solid var(--border-subtle);border-radius:10px;overflow:hidden;background:var(--bg-card);box-shadow:var(--shadow-card)}
.rt-header{display:grid;grid-template-columns:1.2fr 1fr 1fr 1.5fr;gap:0;padding:12px 20px;background:rgba(0,177,171,0.08);border-bottom:1px solid var(--border-subtle)}
.rt-header span{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal);font-weight:500}
.rt-row{display:grid;grid-template-columns:1.2fr 1fr 1fr 1.5fr;gap:0;padding:14px 20px;border-bottom:1px solid var(--border-subtle);font-size:.82rem;align-items:center}
.rt-row:last-child{border-bottom:none}
.rt-row span:first-child{color:var(--text-primary);font-weight:500}
.rt-row span{color:var(--text-muted)}
.rt-row .rt-time{font-family:'JetBrains Mono',monospace;font-size:.78rem;color:var(--teal)}

/* ========== ROLE CHAIN ========== */
.role-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;max-width:760px}
.role-card{padding:24px;border-radius:10px;background:var(--bg-card);border:1px solid var(--border-subtle);box-shadow:var(--shadow-card);position:relative}
.role-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:10px 10px 0 0}
.role-card:nth-child(1)::before{background:var(--teal)}
.role-card:nth-child(2)::before{background:var(--orange)}
.role-card:nth-child(3)::before{background:var(--sky)}
.role-card .rc-role{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--teal);margin-bottom:8px}
.role-card:nth-child(2) .rc-role{color:var(--orange)}
.role-card:nth-child(3) .rc-role{color:var(--sky)}
.role-card h4{font-weight:600;font-size:.92rem;color:var(--text-primary);margin-bottom:6px}
.role-card p{font-size:.82rem;color:var(--text-muted);line-height:1.55}
.role-connector{font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--teal);letter-spacing:.06em;padding:14px 22px;border:1px dashed var(--teal-dim);border-radius:8px;background:var(--bg-glass);max-width:760px;margin-top:20px;text-align:center}

/* ========== CHANGE GRID ========== */
.change-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:760px}
.change-card{padding:22px;border-radius:10px;background:var(--bg-card);border:1px solid var(--border-subtle);box-shadow:var(--shadow-card)}
.change-card .cc-label{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px}
.change-card.before .cc-label{color:var(--pink)}
.change-card.after .cc-label{color:var(--teal)}
.change-card h4{font-weight:600;font-size:.9rem;color:var(--text-primary);margin-bottom:6px}
.change-card p{font-size:.82rem;color:var(--text-muted);line-height:1.55}
.change-card ul{list-style:none;padding:0;margin-top:8px}
.change-card li{font-size:.82rem;color:var(--text-muted);line-height:1.55;padding:4px 0;padding-left:16px;position:relative}
.change-card.before li::before{content:'×';position:absolute;left:0;color:var(--pink);font-weight:600}
.change-card.after li::before{content:'✓';position:absolute;left:0;color:var(--teal);font-weight:600;font-size:.75rem}

/* ========== CLOSER SLIDE ========== */
.slide-closer{text-align:center;align-items:center}
.slide-closer h2{max-width:600px;text-align:center}
.closer-meta{margin-top:40px;font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--text-muted);letter-spacing:.1em}

/* ========== DECK NAV ========== */
.deck-nav{position:fixed;bottom:32px;left:50%;transform:translateX(-50%);z-index:100;display:flex;align-items:center;gap:16px;background:var(--bg-card);backdrop-filter:blur(16px);border:1px solid var(--border-subtle);border-radius:40px;padding:8px 12px}
.deck-btn{background:none;border:1px solid var(--border-subtle);border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-muted);font-size:1rem;transition:all .25s}
.deck-btn:hover:not(:disabled){color:var(--teal);border-color:var(--teal)}
.deck-btn:disabled{opacity:.25;cursor:default}
.deck-btn:focus-visible{outline:2px solid var(--teal);outline-offset:2px}
.deck-dots{display:flex;gap:6px;align-items:center;padding:0 8px}
.deck-dot{width:8px;height:8px;border-radius:50%;background:var(--border-subtle);border:none;padding:0;cursor:pointer;transition:all .25s}
.deck-dot.active{background:var(--teal);box-shadow:0 0 6px var(--teal-glow)}
.deck-dot:hover:not(.active){background:var(--text-muted)}
.deck-dot:focus-visible{outline:2px solid var(--teal);outline-offset:2px}
.deck-counter{font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--text-muted);letter-spacing:.06em;min-width:48px;text-align:center}

/* ========== RESPONSIVE ========== */
@media(max-width:768px){
  html{font-size:16px}
  .slide{padding:70px 24px 100px}
  .tier-grid,.change-grid{grid-template-columns:1fr}
  .role-grid{grid-template-columns:1fr}
  .rt-header,.rt-row{grid-template-columns:1fr;gap:4px;padding:10px 14px}
  .rt-header span:not(:first-child){position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
  .rt-row{font-size:.78rem}
  .slide-meta{flex-direction:column;gap:8px}
  .back-link{top:16px;left:16px;font-size:.6rem;padding:6px 10px}
  .sample-label{top:16px;right:16px;font-size:.5rem;padding:6px 10px}
  .deck-nav{bottom:16px;padding:6px 10px}
}

.skip-link{position:absolute;top:-100px;left:16px;background:var(--teal);color:#fff;padding:8px 16px;border-radius:4px;z-index:9999;font-family:'JetBrains Mono',monospace;font-size:.75rem;text-decoration:none}
.skip-link:focus{top:16px}

/* ========== REDUCED MOTION ========== */
@media(prefers-reduced-motion:reduce){
  .deck-track{transition:none}
}
</style>


<a href="/audience-adaptation#deliverables" class="back-link">&larr; Back to case study</a>
<div class="sample-label">Portfolio sample &middot; Arcline is fictional</div>

<div class="deck-viewport" role="region" aria-label="Slide deck" aria-roledescription="carousel">
  <div class="deck-track" id="deckTrack">

    <!-- SLIDE 1: TITLE -->
    <div class="slide slide-title-page" role="tabpanel" aria-label="Slide 1 of 7" id="slide-0">
      <div class="slide-eyebrow">Arcline &middot; Internal &middot; Data Governance</div>
      <h1>Data Governance <em>Framework</em></h1>
      <p class="slide-title-sub">What the framework covers, how it's structured, what changes for your team. Designed for async review across the department.</p>
      <div class="slide-meta"><span>Prepared by the Data Governance Council</span><span>Q2 2025</span></div>
    </div>

    <!-- SLIDE 2: THE CHALLENGE -->
    <div class="slide" role="tabpanel" aria-label="Slide 2 of 7" id="slide-1" style="background:radial-gradient(ellipse 70% 50% at 30% 50%,rgba(236,12,109,0.04) 0%,transparent 70%),var(--bg-primary)">
      <div class="slide-eyebrow">01 &middot; The Challenge</div>
      <h2>Arcline handles sensitive data across every business unit. No unified system governs how.</h2>
      <p class="slide-lead">Data handling currently depends on team-level norms. Those norms vary across departments, and new hires inherit them without documentation. The company's regulatory obligations have expanded; the practices have not kept pace.</p>
    </div>

    <!-- SLIDE 3: CLASSIFICATION -->
    <div class="slide" role="tabpanel" aria-label="Slide 3 of 7" id="slide-2" style="background:radial-gradient(ellipse 60% 50% at 60% 40%,rgba(0,177,171,0.06) 0%,transparent 70%),var(--bg-primary)">
      <div class="slide-eyebrow">02 &middot; Classification</div>
      <h2>Four tiers, based on what happens if the data is <em>exposed.</em></h2>
      <p class="slide-lead">Every data asset the company holds falls into one of these categories. The tier determines the protections and response timeline, with accountability assigned at each level.</p>
      <div class="tier-grid">
        <div class="tier-card critical">
          <div class="tc-label">Tier 1 &mdash; Restricted</div>
          <h4>Regulatory notification required</h4>
          <p>Health records, financial credentials, government-issued IDs. Exposure triggers mandatory reporting within 72 hours.</p>
        </div>
        <div class="tier-card high">
          <div class="tc-label">Tier 2 &mdash; Confidential</div>
          <h4>Material business harm</h4>
          <p>Unreleased financials, vendor contract terms, pre-board audit findings. No regulatory mandate but significant organizational damage.</p>
        </div>
        <div class="tier-card standard">
          <div class="tc-label">Tier 3 &mdash; Internal</div>
          <h4>Standard protections</h4>
          <p>Departmental planning docs, internal communications. Baseline encryption and standard access controls.</p>
        </div>
        <div class="tier-card public">
          <div class="tc-label">Tier 4 &mdash; Public</div>
          <h4>Cleared for distribution</h4>
          <p>Press releases, published financials. Already through the approval process.</p>
        </div>
      </div>
    </div>

    <!-- SLIDE 4: INCIDENT RESPONSE -->
    <div class="slide" role="tabpanel" aria-label="Slide 4 of 7" id="slide-3" style="background:radial-gradient(ellipse 60% 50% at 40% 50%,rgba(0,177,171,0.06) 0%,transparent 70%),var(--bg-primary)">
      <div class="slide-eyebrow">03 &middot; Incident Response</div>
      <h2>When something goes wrong, the timeline is already <em>defined.</em></h2>
      <p class="slide-lead">Every incident follows the same escalation path. The tier of the affected data determines the speed and scope of the response.</p>
      <div class="response-table">
        <div class="rt-header">
          <span>Category</span>
          <span>Trigger</span>
          <span>Timeline</span>
          <span>What happens</span>
        </div>
        <div class="rt-row">
          <span>Category A</span>
          <span>Tier 1, external exposure</span>
          <span class="rt-time">6 hours</span>
          <span>Full breach protocol. Executive briefing. Regulatory notification begins.</span>
        </div>
        <div class="rt-row">
          <span>Category B</span>
          <span>Tier 2 or Tier 1 contained</span>
          <span class="rt-time">48 hours</span>
          <span>Domain Owner leads response. Contained investigation, remediation plan.</span>
        </div>
        <div class="rt-row">
          <span>Category C</span>
          <span>Suspected, unconfirmed</span>
          <span class="rt-time">5 business days</span>
          <span>Security team investigates. Classify or close within the window.</span>
        </div>
      </div>
    </div>

    <!-- SLIDE 5: OWNERSHIP -->
    <div class="slide" role="tabpanel" aria-label="Slide 5 of 7" id="slide-4" style="background:radial-gradient(ellipse 60% 50% at 60% 60%,rgba(0,177,171,0.06) 0%,transparent 70%),var(--bg-primary)">
      <div class="slide-eyebrow">04 &middot; Ownership Model</div>
      <h2>Every data domain has three roles. Your first contact is your <em>steward.</em></h2>
      <p class="slide-lead">The framework separates governance decisions from implementation. Each role has a defined scope and a clear escalation path.</p>
      <div class="role-grid">
        <div class="role-card">
          <div class="rc-role">Domain Owner</div>
          <h4>VP-level accountability</h4>
          <p>Sets classification policy for their domain. Accountable for regulatory compliance. Makes the final call during an incident.</p>
        </div>
        <div class="role-card">
          <div class="rc-role">Data Steward</div>
          <h4>Day-to-day governance</h4>
          <p>Your first point of contact for any data question. Maintains access lists, runs quarterly reviews, coordinates with legal as needed.</p>
        </div>
        <div class="role-card">
          <div class="rc-role">Custodians</div>
          <h4>Technical implementation</h4>
          <p>Implements the controls. Manages encryption and access provisioning based on steward and owner directives.</p>
        </div>
      </div>
      <div class="role-connector">Governance decisions flow down. Incident reports flow up. The steward is the bridge.</div>
    </div>

    <!-- SLIDE 6: WHAT CHANGES -->
    <div class="slide" role="tabpanel" aria-label="Slide 6 of 7" id="slide-5" style="background:radial-gradient(ellipse 50% 50% at 40% 60%,rgba(0,177,171,0.08) 0%,transparent 70%),var(--bg-primary)">
      <div class="slide-eyebrow">05 &middot; What Changes</div>
      <h2>Starting this quarter, data handling follows the <em>framework.</em></h2>
      <p class="slide-lead">The shift is structural. Individual judgment gets replaced by classification-driven protections with a defined escalation path.</p>
      <div class="change-grid">
        <div class="change-card before">
          <div class="cc-label">Current state</div>
          <h4>Team norms and individual judgment</h4>
          <ul>
            <li>Data handling varies by department</li>
            <li>Incident response assembled on the fly</li>
            <li>No documented classification for most assets</li>
            <li>Access decisions made by whoever is closest to the data</li>
          </ul>
        </div>
        <div class="change-card after">
          <div class="cc-label">Under the framework</div>
          <h4>Classification determines protections</h4>
          <ul>
            <li>Every asset assigned a tier with defined controls</li>
            <li>Incident response follows a documented protocol</li>
            <li>Named owners and stewards for each data domain</li>
            <li>When in doubt, treat as confidential and contact your steward</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- SLIDE 7: CLOSER -->
    <div class="slide slide-closer" role="tabpanel" aria-label="Slide 7 of 7" id="slide-6" style="background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(0,177,171,0.08) 0%,transparent 70%),var(--bg-secondary)">
      <div class="slide-eyebrow">06</div>
      <h2>Two things to remember from this deck: your <em>steward's name</em> and when to <em>file a report.</em></h2>
      <p class="slide-lead" style="text-align:center;margin-left:auto;margin-right:auto">The full technical reference is available on the governance wiki. Reach out to your department's data steward with questions.</p>
      <div class="closer-meta">Arcline &middot; Data Governance Framework &middot; Internal</div>
    </div>

  </div>
</div>

<!-- DECK NAV -->
<nav class="deck-nav" aria-label="Slide navigation">
  <button class="deck-btn" id="deckPrev" aria-label="Previous slide" disabled>&#8592;</button>
  <div class="deck-dots" id="deckDots" role="tablist" aria-label="Slide indicators"></div>
  <div class="deck-counter" id="deckCounter" aria-live="polite">1 / 7</div>
  <button class="deck-btn" id="deckNext" aria-label="Next slide">&#8594;</button>
</nav>


<script is:inline>
const track = document.getElementById('deckTrack');
const slides = track.querySelectorAll('.slide');
const prev = document.getElementById('deckPrev');
const next = document.getElementById('deckNext');
const dotsC = document.getElementById('deckDots');
const counter = document.getElementById('deckCounter');
const total = slides.length;
let cur = 0;

/* Build dots */
slides.forEach((_, i) => {
  const d = document.createElement('button');
  d.className = 'deck-dot' + (i === 0 ? ' active' : '');
  d.setAttribute('role', 'tab');
  d.setAttribute('aria-label', 'Slide ' + (i + 1));
  d.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
  d.addEventListener('click', () => go(i));
  dotsC.appendChild(d);
});
const dots = dotsC.querySelectorAll('.deck-dot');

function go(n) {
  slides[cur].setAttribute('aria-hidden', 'true');
  dots[cur].classList.remove('active');
  dots[cur].setAttribute('aria-selected', 'false');
  cur = n;
  track.style.transform = 'translateX(-' + (cur * 100) + 'vw)';
  slides[cur].removeAttribute('aria-hidden');
  dots[cur].classList.add('active');
  dots[cur].setAttribute('aria-selected', 'true');
  prev.disabled = cur === 0;
  next.disabled = cur === total - 1;
  counter.textContent = (cur + 1) + ' / ' + total;
}

prev.addEventListener('click', () => { if (cur > 0) go(cur - 1); });
next.addEventListener('click', () => { if (cur < total - 1) go(cur + 1); });

/* Keyboard navigation */
document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' && cur < total - 1) go(cur + 1);
  if (e.key === 'ArrowLeft' && cur > 0) go(cur - 1);
});

/* Initialize: hide all but first */
slides.forEach((s, i) => { if (i > 0) s.setAttribute('aria-hidden', 'true'); });
</script>
</BaseLayout>
