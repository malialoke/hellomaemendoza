---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mae Mendoza — Senior Content Specialist" skipTarget="#section-1">
<style is:inline>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600;1,700&family=JetBrains+Mono:wght@400;500&display=swap');
@import url('https://api.fontshare.com/v2/css?f[]=general-sans@300,400,500,600&display=swap');

*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

/* ========================================
   DESIGN TOKENS
   ======================================== */
:root {
  --font-heading: 'Playfair Display', Georgia, serif;
  --font-body: 'General Sans', 'Helvetica Neue', sans-serif;
  --font-mono: 'JetBrains Mono', 'Courier New', monospace;
  --grain-opacity: 0.025;
  --spine-width: 1px;
  --section-padding-x: 60px;
  --col-left: 38%;
  --col-right: 62%;
  --transition-base: 0.3s ease;
  --transition-slow: 0.5s ease;
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 20px;
}

[data-theme="dark"] {
  --bg: #0a0a0a;
  --bg-card: rgba(20, 20, 20, 0.85);
  --bg-tab-bar: rgba(20, 20, 20, 0.6);
  --bg-tab-hover: rgba(255, 255, 255, 0.04);
  --bg-tab-active: rgba(255, 255, 255, 0.08);
  --text-primary: #ffffff;
  --text-body: #c8c8c8;
  --text-muted: #777777;
  --text-surface-label: #999999;
  --magenta: #e8457a;
  --teal: #00d4cc;
  --violet: #a78bfa;
  --coral: #f4845f;
  --gold: #f6c744;
  --green: #34d399;
  --blue: #60a5fa;
  --pink: #f0abfc;
  --border-subtle: rgba(255,255,255,0.06);
  --border-hover: rgba(255,255,255,0.14);
  --border-active: rgba(255,255,255,0.2);
  --glow-magenta: rgba(232,69,122,0.15);
  --glow-teal: rgba(0,212,204,0.08);
  --spine-color: rgba(255,255,255,0.06);
  --shadow-card: 0 4px 32px rgba(0, 0, 0, 0.5);
  --tab-indicator: var(--magenta);
}

[data-theme="light"] {
  --bg: #faf8f6;
  --bg-card: rgba(255,255,255,0.95);
  --bg-tab-bar: rgba(255, 255, 255, 0.7);
  --bg-tab-hover: rgba(0, 0, 0, 0.03);
  --bg-tab-active: rgba(0, 0, 0, 0.06);
  --text-primary: #0a0a0a;
  --text-body: #3b4249;
  --text-muted: #6b7580;
  --text-surface-label: #6b7580;
  --magenta: #c23062;
  --teal: #00c4be;
  --violet: #7c5fd6;
  --coral: #e06840;
  --gold: #d4a520;
  --green: #1ea670;
  --blue: #4a8fd6;
  --pink: #c77dd6;
  --border-subtle: rgba(100,120,140,0.12);
  --border-hover: rgba(100,120,140,0.22);
  --border-active: rgba(100,120,140,0.3);
  --glow-magenta: rgba(194,48,98,0.08);
  --glow-teal: rgba(0,196,190,0.06);
  --spine-color: rgba(194,48,98,0.18);
  --shadow-card: 0 2px 20px rgba(0, 0, 0, 0.06);
  --tab-indicator: var(--magenta);
}

/* Light mode: subtle warm texture on body */
[data-theme="light"] body {
  background-image:
    radial-gradient(circle at 20% 50%, rgba(194,48,98,0.02) 0%, transparent 50%),
    radial-gradient(circle at 80% 50%, rgba(0,196,190,0.015) 0%, transparent 50%);
}

/* Light mode: graph-paper grid on cases section */
[data-theme="light"] .section-cases {
  background-color: var(--bg);
  background-image:
    linear-gradient(rgba(100,120,140,0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(100,120,140,0.08) 1px, transparent 1px);
  background-size: 32px 32px;
}

[data-theme="rainbow"] {
  --bg: #0a0a0a;
  --bg-card: rgba(10,10,10,0.75);
  --bg-tab-bar: rgba(10, 10, 10, 0.6);
  --bg-tab-hover: rgba(255, 255, 255, 0.04);
  --bg-tab-active: rgba(255, 255, 255, 0.08);
  --text-primary: #ffffff;
  --text-body: #c8c8c8;
  --text-muted: #999999;
  --text-surface-label: #bbbbbb;
  --magenta: #ff2d78;
  --teal: #00ffd5;
  --violet: #c4b5fd;
  --coral: #f4845f;
  --gold: #f6c744;
  --green: #34d399;
  --blue: #60a5fa;
  --pink: #f0abfc;
  --border-subtle: rgba(255,255,255,0.08);
  --border-hover: rgba(255,255,255,0.18);
  --border-active: rgba(255,255,255,0.25);
  --glow-magenta: rgba(255,45,120,0.2);
  --glow-teal: rgba(0,255,213,0.1);
  --spine-color: rgba(255,255,255,0.08);
  --shadow-card: 0 4px 32px rgba(0, 0, 0, 0.5);
  --tab-indicator: var(--magenta);
}

/* ========================================
   BASE
   ======================================== */
html {
  font-size: 17px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text-body);
  overflow-x: hidden;
  transition: background 0.5s, color 0.3s;
}

/* Film grain */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity: var(--grain-opacity);
  pointer-events: none;
  z-index: 10000;
}

/* Rainbow polka dots */
[data-theme="rainbow"] body {
  background-image:
    radial-gradient(circle, rgba(255,255,255,0.055) 14px, transparent 14px),
    radial-gradient(circle, rgba(255,255,255,0.055) 14px, transparent 14px);
  background-size: 80px 80px;
  background-position: 0 0, 40px 40px;
}

/* ========================================
   SCROLL SNAP
   ======================================== */
html {
  scroll-snap-type: y mandatory;
}

.section {
  min-height: 100vh;
  scroll-snap-align: start;
  position: relative;
  display: flex;
  overflow: hidden;
}

/* ========================================
   SPINE
   ======================================== */
.spine {
  position: fixed;
  top: 0;
  bottom: 0;
  left: var(--col-left);
  width: var(--spine-width);
  background: var(--spine-color);
  z-index: 100;
  pointer-events: none;
  transition: background 0.3s;
}

[data-theme="rainbow"] .spine {
  background: linear-gradient(
    to bottom,
    transparent 0%,
    var(--magenta) 10%,
    var(--coral) 25%,
    var(--gold) 40%,
    var(--green) 55%,
    var(--teal) 70%,
    var(--blue) 80%,
    var(--violet) 90%,
    transparent 100%
  );
}

/* ========================================
   MODE TOGGLE
   ======================================== */
.mode-toggle {
  position: fixed;
  top: 20px;
  right: 24px;
  z-index: 9000;
  display: flex;
  gap: 3px;
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border-subtle);
  border-radius: 40px;
  padding: 4px;
}

.mode-btn {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  background: transparent;
  color: var(--text-muted);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  padding: 0;
}
.mode-btn:hover { color: var(--text-primary); }
.mode-btn.active { background: var(--text-primary); color: var(--bg); box-shadow: 0 1px 8px rgba(0,0,0,0.2); }
.mode-btn.rainbow-btn.active {
  background: linear-gradient(135deg, #ff2d78, #f4845f, #f6c744, #34d399, #00ffd5, #60a5fa, #c4b5fd);
  color: #0a0a0a;
}

/* Contact section needs different toggle colors */
.section-contact-active .mode-toggle {
  background: rgba(0,0,0,0.6);
}

/* ========================================
   NAV DOTS
   ======================================== */
.nav-dots {
  position: fixed;
  right: 24px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 9000;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.nav-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 1px solid var(--text-muted);
  background: transparent;
  cursor: pointer;
  transition: all 0.3s;
  padding: 0;
}
.nav-dot:hover { border-color: var(--text-primary); }
.nav-dot.active {
  background: var(--magenta);
  border-color: var(--magenta);
  transform: scale(1.3);
}

[data-theme="rainbow"] .nav-dot:nth-child(1).active { background: var(--magenta); border-color: var(--magenta); }
[data-theme="rainbow"] .nav-dot:nth-child(2).active { background: var(--coral); border-color: var(--coral); }
[data-theme="rainbow"] .nav-dot:nth-child(3).active { background: var(--gold); border-color: var(--gold); }
[data-theme="rainbow"] .nav-dot:nth-child(4).active { background: var(--teal); border-color: var(--teal); }
[data-theme="rainbow"] .nav-dot:nth-child(5).active { background: var(--violet); border-color: var(--violet); }

/* ========================================
   SHARED SECTION ELEMENTS
   ======================================== */
.section-num {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 20px;
}

.section-title {
  font-family: var(--font-heading);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.2;
  margin-bottom: 12px;
}

.section-subtitle {
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 300;
  color: var(--text-muted);
  line-height: 1.6;
}

/* Rainbow treatment for second lines of section headers */
[data-theme="rainbow"] .rainbow-line {
  background: linear-gradient(90deg, var(--magenta), var(--coral), var(--gold), var(--green), var(--teal), var(--blue), var(--violet));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ========================================
   SECTION 1: HERO
   ======================================== */
.hero {
  display: flex;
  align-items: stretch;
}

.hero-left {
  width: var(--col-left);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  padding: 0 var(--section-padding-x) 100px;
  position: relative;
}

.hero-left::before {
  content: '';
  position: absolute;
  bottom: 10%;
  left: 20%;
  width: 500px;
  height: 400px;
  background: radial-gradient(ellipse, var(--glow-magenta) 0%, transparent 70%);
  pointer-events: none;
}

/* Dark mode: polka dots on hero left */
[data-theme="dark"] .hero-left {
  background-image:
    radial-gradient(circle, rgba(232,69,122,0.06) 60px, transparent 60px),
    radial-gradient(circle, rgba(232,69,122,0.06) 60px, transparent 60px);
  background-size: 200px 200px;
  background-position: 30px 20px, 130px 120px;
}

/* Light mode: polka dots on hero left */
[data-theme="light"] .hero-left {
  background-image:
    radial-gradient(circle, rgba(194,48,98,0.5) 98px, transparent 101px),
    radial-gradient(circle, rgba(194,48,98,0.5) 98px, transparent 101px);
  background-size: 320px 320px;
  background-position: 10px 20px, 170px 180px;
}
[data-theme="light"] .hero-left::before {
  display: none;
}

.hero-right {
  width: var(--col-right);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 80px 0 var(--section-padding-x);
  position: relative;
}

.hero-right::before {
  content: '';
  position: absolute;
  top: 30%;
  right: 10%;
  width: 400px;
  height: 350px;
  background: radial-gradient(ellipse, var(--glow-teal) 0%, transparent 70%);
  pointer-events: none;
}

.hero-name {
  font-family: var(--font-heading);
  font-size: clamp(4.5rem, 8.5vw, 5.5rem);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 0.92;
  position: relative;
  z-index: 1;
}

.hero-name-first { display: block; }

/* Light mode: soft white glow on hero name */
[data-theme="light"] .hero-name-first,
[data-theme="light"] .hero-name-last {
  text-shadow: 0 0 20px rgba(255,255,255,0.9), 0 0 40px rgba(255,255,255,0.6), 0 0 60px rgba(255,255,255,0.3);
}
[data-theme="light"] .hero-role {
  color: var(--magenta);
  background: #faf8f6;
  width: fit-content;
  padding: 1px 6px;
}

.hero-name-last {
  display: block;
  color: var(--magenta);
}

/* Rainbow: full spectrum on last name */
[data-theme="rainbow"] .hero-name-last {
  background: linear-gradient(90deg, var(--magenta), var(--coral), var(--gold), var(--green), var(--teal), var(--blue), var(--violet));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: inline-block;
  padding-bottom: 0.08em;
  line-height: 1.05;
}

/* Rainbow: polka-dot background on hero left, white name override */
/* Freeform placement, three size tiers: L=95px, M=65px, S=40px */
[data-theme="rainbow"] .hero-left {
  background:
    radial-gradient(circle at 10% 8%,  rgba(255,45,120,0.32) 95px, transparent 95px),
    radial-gradient(circle at 42% 5%,  rgba(255,214,0,0.28) 65px, transparent 65px),
    radial-gradient(circle at 72% 14%, rgba(0,194,255,0.30) 95px, transparent 95px),
    radial-gradient(circle at 95% 3%,  rgba(168,85,247,0.26) 40px, transparent 40px),
    radial-gradient(circle at 25% 32%, rgba(255,107,53,0.30) 65px, transparent 65px),
    radial-gradient(circle at 58% 28%, rgba(0,232,123,0.28) 40px, transparent 40px),
    radial-gradient(circle at 85% 38%, rgba(168,85,247,0.32) 95px, transparent 95px),
    radial-gradient(circle at 8% 55%,  rgba(0,232,123,0.28) 65px, transparent 65px),
    radial-gradient(circle at 45% 52%, rgba(0,194,255,0.30) 95px, transparent 95px),
    radial-gradient(circle at 70% 58%, rgba(255,45,120,0.26) 40px, transparent 40px),
    radial-gradient(circle at 30% 72%, rgba(255,214,0,0.30) 95px, transparent 95px),
    radial-gradient(circle at 60% 78%, rgba(255,107,53,0.28) 65px, transparent 65px),
    radial-gradient(circle at 88% 70%, rgba(0,194,255,0.26) 40px, transparent 40px),
    radial-gradient(circle at 15% 90%, rgba(168,85,247,0.28) 65px, transparent 65px),
    radial-gradient(circle at 50% 92%, rgba(255,45,120,0.26) 40px, transparent 40px),
    radial-gradient(circle at 82% 92%, rgba(0,232,123,0.32) 95px, transparent 95px),
    #0a0a0a;
}
[data-theme="rainbow"] .hero-left::before {
  display: none;
}
[data-theme="rainbow"] .hero-name-first {
  color: #ffffff;
  -webkit-text-fill-color: #ffffff;
  text-shadow: 1px 2px 2px rgba(0,0,0,0.3);
}
[data-theme="rainbow"] .hero-role {
  color: rgba(255,255,255,0.8);
}

.hero-role {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: 20px;
  position: relative;
  z-index: 1;
}

.hero-divider {
  width: 48px;
  height: 2px;
  background: var(--magenta);
  margin-bottom: 32px;
  position: relative;
  z-index: 1;
}

[data-theme="rainbow"] .hero-divider {
  width: 72px;
  background: linear-gradient(90deg, var(--magenta), var(--coral), var(--gold), var(--green), var(--teal), var(--blue), var(--violet));
}

.hero-statement {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 3.8vw, 2.2rem);
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.25;
  margin-bottom: 24px;
  max-width: 520px;
  position: relative;
  z-index: 1;
}

.hero-statement em {
  font-style: italic;
  color: var(--magenta);
}

[data-theme="rainbow"] .hero-statement em {
  background: linear-gradient(90deg, var(--magenta), var(--coral), var(--gold), var(--green), var(--teal), var(--violet));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-supporting {
  font-family: var(--font-body);
  font-size: 1.15rem;
  font-weight: 300;
  color: var(--text-muted);
  line-height: 1.85;
  max-width: 460px;
  position: relative;
  z-index: 1;
}

.scroll-cue {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  color: var(--text-muted);
  animation: cue-float 2.5s ease-in-out infinite;
  z-index: 1;
}
.scroll-cue span {
  font-family: var(--font-mono);
  font-size: 0.5rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}
.scroll-cue svg { width: 14px; height: 14px; opacity: 0.4; }

@keyframes cue-float {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(5px); }
}

/* ========================================
   SECTION 2: DEMO — Grid-breaking layout
   Top row: label/title left, subtitle right
   Bottom: full-width demo
   ======================================== */
.section-demo {
  justify-content: center;
}

/* Light mode: polka dot texture on demo section */
[data-theme="light"] .section-demo {
  background-image:
    radial-gradient(circle, rgba(194,48,98,0.06) 98px, transparent 101px),
    radial-gradient(circle, rgba(194,48,98,0.06) 98px, transparent 101px);
  background-size: 320px 320px;
  background-position: 10px 20px, 170px 180px;
}

/* Demo section: two-column layout matching spine */
.demo-left {
  width: var(--col-left);
  padding: 0 var(--section-padding-x);
  display: flex;
  align-items: center;
  flex-shrink: 0;
  position: relative;
}

/* Dark mode: subtle magenta radial glow on demo-left */
[data-theme="dark"] .demo-left::before {
  content: '';
  position: absolute;
  top: 30%;
  left: 10%;
  width: 500px;
  height: 500px;
  background: radial-gradient(ellipse, rgba(232,69,122,0.1) 0%, transparent 70%);
  pointer-events: none;
}

.demo-left-inner {
  width: 100%;
}

.demo-left .section-subtitle {
  margin-top: 16px;
  max-width: 420px;
}

.demo-nav {
  margin-bottom: 16px;
}

.demo-right {
  width: var(--col-right);
  padding: 0 80px 0 var(--section-padding-x);
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

/* ========================================
   ATLAS DEMO COMPONENT
   ======================================== */
.demo-nav .tab-bar {
  display: flex;
  flex-direction: row;
  gap: 2px;
  background: var(--bg-tab-bar);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-md);
  padding: 4px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  flex-shrink: 0;
}
[data-theme="dark"] .demo-nav .tab-bar { background: #111111; }
[data-theme="light"] .demo-nav .tab-bar { background: #f5f3f1; }
[data-theme="rainbow"] .demo-nav .tab-bar { background: #0d0d0d; }
/* Tab bar is now transparent/unstyled in vertical layout */
.demo-nav .tab-bar::-webkit-scrollbar { display: none; }

.demo-nav .tab-btn {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
  padding: 8px 14px;
  border: none;
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.25s ease;
  position: relative;
  flex-shrink: 0;
}
.demo-nav .tab-btn:hover {
  background: var(--bg-tab-hover);
  color: var(--text-body);
}
.demo-nav .tab-btn:focus-visible {
  outline: 2px solid var(--tab-indicator);
  outline-offset: -2px;
}
.demo-nav .tab-btn.active {
  background: var(--bg-tab-active);
  color: var(--text-primary);
  font-weight: 500;
}
.demo-nav .tab-btn.active::after {
  content: '';
  position: absolute;
  bottom: 2px;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 2px;
  border-radius: 1px;
  background: var(--tab-indicator);
}

/* Rainbow tab colors */
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="0"].active::after { background: var(--magenta); }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="1"].active::after { background: var(--coral); }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="2"].active::after { background: var(--gold); }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="3"].active::after { background: #a3e635; }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="4"].active::after { background: #0891b2; }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="5"].active::after { background: var(--violet); }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="0"].active { color: var(--magenta); }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="1"].active { color: var(--coral); }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="2"].active { color: var(--gold); }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="3"].active { color: #a3e635; }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="4"].active { color: #0891b2; }
[data-theme="rainbow"] .demo-nav .tab-btn[data-index="5"].active { color: var(--violet); }

.atlas-demo .content-card {
  background: var(--bg-card);
  border: 1px solid var(--border-subtle);
  border-radius: var(--radius-lg);
  padding: 32px 36px;
  box-shadow: var(--shadow-card);
  transition: border-color var(--transition-base), background var(--transition-base);
  position: relative;
  overflow: hidden;
}
/* Opaque content-card backgrounds to prevent spine bleed */
[data-theme="dark"] .atlas-demo .content-card { background: #141414; }
[data-theme="light"] .atlas-demo .content-card { background: #ffffff; }
[data-theme="rainbow"] .atlas-demo .content-card { background: #0e0e0e; }
.atlas-demo .content-card:hover {
  border-color: var(--border-hover);
}

[data-theme="rainbow"] .atlas-demo .content-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--magenta), var(--coral), var(--gold), var(--green), var(--teal), var(--blue), var(--violet));
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

.atlas-demo .surface-label {
  font-family: var(--font-mono);
  font-size: 0.56rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-surface-label);
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.atlas-demo .surface-label::before {
  content: '';
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--tab-indicator);
  flex-shrink: 0;
}

[data-theme="rainbow"] .atlas-demo .surface-label-dot-0::before { background: var(--magenta); }
[data-theme="rainbow"] .atlas-demo .surface-label-dot-1::before { background: var(--coral); }
[data-theme="rainbow"] .atlas-demo .surface-label-dot-2::before { background: var(--gold); }
[data-theme="rainbow"] .atlas-demo .surface-label-dot-3::before { background: #a3e635; }
[data-theme="rainbow"] .atlas-demo .surface-label-dot-4::before { background: #0891b2; }
[data-theme="rainbow"] .atlas-demo .surface-label-dot-5::before { background: var(--violet); }

.atlas-demo .tab-panel {
  display: none;
  animation: atlasFadeIn 0.35s ease;
}
.atlas-demo .tab-panel.active { display: block; }

@keyframes atlasFadeIn {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}

.atlas-demo .panel-columns {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}
@media (min-width: 768px) {
  .atlas-demo .panel-columns {
    grid-template-columns: 60fr 35fr;
    gap: 5%;
    align-items: start;
  }
  .atlas-demo .panel-col-right {
    border-left: 1px solid var(--border-subtle);
    padding-left: 5%;
  }
  [data-theme="rainbow"] .atlas-demo .panel-col-right {
    border-image: linear-gradient(to bottom, var(--magenta), var(--teal), var(--violet)) 1;
  }
}

.atlas-demo .panel-col-right .content-body {
  font-size: 0.78rem;
  line-height: 1.55;
  color: var(--text-muted);
}

.atlas-demo .content-heading {
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--magenta);
  line-height: 1.35;
  margin-bottom: 12px;
}
.atlas-demo .content-body {
  font-family: var(--font-body);
  font-size: 0.84rem;
  color: var(--text-body);
  line-height: 1.6;
  margin-bottom: 12px;
}
.atlas-demo .content-body:last-child { margin-bottom: 0; }
.atlas-demo .content-subhead {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-primary);
  margin-bottom: 8px;
  margin-top: 16px;
}
.atlas-demo .panel-col-right .content-subhead {
  margin-top: 0;
}
.atlas-demo .content-body code {
  font-family: var(--font-mono);
  font-size: 0.82em;
  background: rgba(255,255,255,0.06);
  padding: 2px 7px;
  border-radius: 4px;
  color: var(--teal);
}
[data-theme="light"] .atlas-demo .content-body code {
  background: rgba(0,0,0,0.05);
  color: var(--violet);
}

.atlas-demo .product-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid var(--border-subtle);
  width: 100%;
}
[data-theme="rainbow"] .atlas-demo .product-badge {
  border-image: linear-gradient(90deg, var(--magenta), var(--teal), var(--violet)) 1;
}
.atlas-demo .product-badge svg {
  width: 14px; height: 14px; opacity: 0.5;
}

/* ========================================
   SECTION 3: CASE STUDIES — Two-column, stacked cards
   ======================================== */
.section-cases {
  background: var(--bg);
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 32px 32px;
}

[data-theme="rainbow"] .section-cases {
  background-color: var(--bg);
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 32px 32px;
}

.cases-left {
  width: var(--col-left);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 var(--section-padding-x);
  position: sticky;
  top: 0;
  height: 100vh;
}

/* Dark mode: graph-paper grid on cases-left */
[data-theme="dark"] .cases-left {
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 32px 32px;
}

.cases-title {
  font-family: var(--font-heading);
  font-size: clamp(1.6rem, 2.8vw, 2.2rem);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
  margin-top: 16px;
}

.cases-title .rainbow-line {
  display: block;
}

.cases-subtitle {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-top: 16px;
  max-width: 320px;
}

.cases-right {
  width: var(--col-right);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24px;
  padding: 80px 80px 80px var(--section-padding-x);
}

/* Flip card container */
.flip-card {
  perspective: 1200px;
  min-height: 220px;
  cursor: pointer;
  max-width: 70%;
}

.flip-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s ease;
  transform-style: preserve-3d;
}

.flip-card.flipped .flip-card-inner {
  transform: rotateY(180deg);
}

.flip-card-front,
.flip-card-back {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 16px;
  padding: 32px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

/* Front face */
.flip-card-front {
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border-subtle);
  transition: border-color 0.3s;
  border-top: 3px solid var(--magenta);
  position: relative;
}

.flip-card:nth-child(2) .flip-card-front {
  border-top-color: var(--teal);
}
.flip-card:nth-child(3) .flip-card-front {
  border-top-color: var(--violet);
}

/* Case number watermark */
.flip-card-front::before {
  content: '01';
  position: absolute;
  top: -10px;
  right: 20px;
  font-family: var(--font-heading);
  font-size: 6rem;
  font-weight: 800;
  line-height: 1;
  color: var(--magenta);
  opacity: 0.06;
  pointer-events: none;
}
.flip-card:nth-child(2) .flip-card-front::before {
  content: '02';
  color: var(--teal);
}
.flip-card:nth-child(3) .flip-card-front::before {
  content: '03';
  color: var(--violet);
}
[data-theme="light"] .flip-card-front::before { opacity: 0.08; }
[data-theme="rainbow"] .flip-card-front::before { opacity: 0.1; }

/* Light mode: all card accents go pink */
[data-theme="light"] .flip-card:nth-child(2) .flip-card-front { border-top-color: var(--magenta); }
[data-theme="light"] .flip-card:nth-child(3) .flip-card-front { border-top-color: var(--magenta); }
[data-theme="light"] .flip-card:nth-child(2) .flip-card-front::before { color: var(--magenta); }
[data-theme="light"] .flip-card:nth-child(3) .flip-card-front::before { color: var(--magenta); }
[data-theme="light"] .flip-card:nth-child(2) .case-title strong { color: var(--magenta); }
[data-theme="light"] .flip-card:nth-child(3) .case-title strong { color: var(--magenta); }
[data-theme="light"] .flip-card:nth-child(2) .case-eyebrow { color: var(--magenta); }
[data-theme="light"] .flip-card:nth-child(3) .case-eyebrow { color: var(--magenta); }
/* ========================================
   CASE LINKS — all three themes
   ======================================== */

/* Light mode: all cards use magenta (nth-child accents are suppressed in light) */
[data-theme="light"] .case-link {
  color: var(--magenta);
  border-color: var(--magenta);
  background: #ffffff;
}
[data-theme="light"] .case-link .pill-link-text { color: var(--magenta); }
[data-theme="light"] .case-link:hover {
  background: var(--magenta);
  color: #ffffff;
}
[data-theme="light"] .case-link:hover .pill-link-text { color: #ffffff; }
[data-theme="light"] .case-link:hover svg { stroke: #ffffff; }

/* Dark mode: each card uses its own accent color */
[data-theme="dark"] .case-link {
  color: var(--magenta);
  border-color: var(--magenta);
  background: transparent;
}
[data-theme="dark"] .flip-card:nth-child(2) .case-link {
  color: var(--teal);
  border-color: var(--teal);
}
[data-theme="dark"] .flip-card:nth-child(3) .case-link {
  color: var(--violet);
  border-color: var(--violet);
}
[data-theme="dark"] .case-link:hover {
  background: var(--magenta);
  color: #ffffff;
}
[data-theme="dark"] .flip-card:nth-child(2) .case-link:hover {
  background: var(--teal);
  color: #000000;
}
[data-theme="dark"] .flip-card:nth-child(3) .case-link:hover {
  background: var(--violet);
  color: #000000;
}
[data-theme="dark"] .case-link:hover svg { stroke: #ffffff; }
[data-theme="dark"] .flip-card:nth-child(2) .case-link:hover svg,
[data-theme="dark"] .flip-card:nth-child(3) .case-link:hover svg { stroke: #000000; }

/* Rainbow pill behavior is inherited from BaseLayout .pill-link.
   No overrides needed for .case-link in rainbow mode. */

.flip-card:hover .flip-card-front {
  border-left-color: var(--border-hover);
  border-right-color: var(--border-hover);
  border-bottom-color: var(--border-hover);
}

/* Rainbow front */
[data-theme="rainbow"] .flip-card .flip-card-front {
  background: linear-gradient(135deg, rgba(255,45,120,0.1), rgba(244,132,95,0.06), rgba(246,199,68,0.04), rgba(0,255,213,0.06), rgba(196,181,253,0.08));
  border-color: rgba(255,255,255,0.1);
  border-top: 3px solid;
  border-image: linear-gradient(to right, var(--magenta), var(--coral), var(--gold), var(--green), var(--teal), var(--blue), var(--violet)) 1;
  border-image-slice: 1 0 0 0;
}

.case-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--magenta);
  margin-bottom: 14px;
}
.flip-card:nth-child(2) .case-eyebrow { color: var(--teal); }
.flip-card:nth-child(3) .case-eyebrow { color: var(--violet); }

.case-title {
  font-family: var(--font-heading);
  font-size: 1.35rem;
  font-weight: 700;
  font-style: normal;
  color: var(--text-primary);
  line-height: 1.35;
  max-width: 95%;
  position: relative;
  z-index: 1;
}
.case-title strong {
  color: var(--magenta);
  font-weight: 700;
}
.flip-card:nth-child(2) .case-title strong {
  color: var(--teal);
}
.flip-card:nth-child(3) .case-title strong {
  color: var(--violet);
}

.case-front-sub {
  font-family: var(--font-body);
  font-size: 0.82rem;
  line-height: 1.55;
  color: var(--text-body);
  margin-top: 12px;
  max-width: 90%;
  position: relative;
  z-index: 1;
}

.flip-hint {
  font-family: var(--font-mono);
  font-size: 0.5rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-top: auto;
  padding-top: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.flip-hint svg {
  width: 12px;
  height: 12px;
  transition: transform 0.3s;
}

.flip-card:hover .flip-hint svg {
  transform: rotateY(30deg);
}

/* Back face */
.flip-card-back {
  transform: rotateY(180deg);
  background: var(--bg-card);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border-hover);
}

[data-theme="rainbow"] .flip-card .flip-card-back {
  background: linear-gradient(135deg, rgba(255,45,120,0.1), rgba(246,199,68,0.06), rgba(0,255,213,0.06), rgba(196,181,253,0.08));
  border-color: rgba(255,255,255,0.12);
}

.case-back-desc {
  font-family: var(--font-body);
  font-size: 0.82rem;
  color: var(--text-body);
  line-height: 1.6;
  margin-bottom: 20px;
}

.case-link {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--magenta);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: auto;
}
.flip-card:nth-child(2) .case-link { color: var(--teal); }
.flip-card:nth-child(3) .case-link { color: var(--violet); }
.case-link svg { width: 12px; height: 12px; }

/* ========================================
   SECTION 4: HOW I THINK
   ======================================== */
.section-think {
  background: var(--bg);
}

/* Dark mode: magenta polka dots on think-left */
[data-theme="dark"] .think-left {
  background-image:
    radial-gradient(circle, rgba(232,69,122,0.06) 60px, transparent 60px),
    radial-gradient(circle, rgba(232,69,122,0.06) 60px, transparent 60px);
  background-size: 200px 200px;
  background-position: 30px 20px, 130px 120px;
}

/* Light mode: bold pink polka dots behind think-left */
[data-theme="light"] .think-left {
  position: sticky;
  background-image:
    radial-gradient(circle, rgba(194,48,98,0.5) 98px, transparent 101px),
    radial-gradient(circle, rgba(194,48,98,0.5) 98px, transparent 101px);
  background-size: 320px 320px;
  background-position: 10px 0px, 170px 160px;
}

/* Light mode: label-maker tape strips on section text */
[data-theme="light"] .think-left .section-num {
  background: #faf8f6;
  width: fit-content;
  padding: 1px 6px;
  position: relative;
  z-index: 1;
}

[data-theme="light"] .think-left .section-title {
  position: relative;
  z-index: 1;
  width: fit-content;
}

[data-theme="light"] .think-left .section-title-label {
  background: #faf8f6;
  padding: 1px 6px;
  box-decoration-break: clone;
  -webkit-box-decoration-break: clone;
}

.think-left {
  width: var(--col-left);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 var(--section-padding-x);
  position: sticky;
  top: 0;
  height: 100vh;
}

.think-right {
  width: var(--col-right);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 20px;
  padding: 60px 80px 60px var(--section-padding-x);
}

.framework-card {
  padding: 28px 0;
  border-bottom: 1px solid var(--border-subtle);
}
.framework-card:last-child { border-bottom: none; }

.framework-num {
  font-family: var(--font-mono);
  font-size: 0.55rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.framework-title {
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
}

/* Framework title accent colors */
.framework-card:nth-child(1) .framework-title { color: var(--magenta); }
.framework-card:nth-child(2) .framework-title { color: var(--magenta); }
.framework-card:nth-child(3) .framework-title { color: var(--magenta); }
.framework-card:nth-child(4) .framework-title { color: var(--magenta); }

.framework-desc {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--text-body);
  line-height: 1.6;
  max-width: 480px;
}

[data-theme="rainbow"] .framework-card:nth-child(1) .framework-num { color: var(--magenta); }
[data-theme="rainbow"] .framework-card:nth-child(2) .framework-num { color: var(--coral); }
[data-theme="rainbow"] .framework-card:nth-child(3) .framework-num { color: var(--gold); }
[data-theme="rainbow"] .framework-card:nth-child(4) .framework-num { color: var(--teal); }

/* Rainbow: titles match their corresponding number color */
[data-theme="rainbow"] .framework-card:nth-child(1) .framework-title { color: var(--magenta); }
[data-theme="rainbow"] .framework-card:nth-child(2) .framework-title { color: var(--coral); }
[data-theme="rainbow"] .framework-card:nth-child(3) .framework-title { color: var(--gold); }
[data-theme="rainbow"] .framework-card:nth-child(4) .framework-title { color: var(--teal); }

/* ========================================
   SECTION 5: CONTACT — Mirrors hero layout
   ======================================== */
.section-contact {
  background: var(--magenta);
  position: relative;
  display: flex;
  align-items: stretch;
}

[data-theme="light"] .section-contact {
  background: var(--magenta);
}

[data-theme="light"] .contact-left {
  background-color: #faf8f6;
  background-image:
    linear-gradient(rgba(100,120,140,0.15) 1px, transparent 1px),
    linear-gradient(90deg, rgba(100,120,140,0.15) 1px, transparent 1px);
  background-size: 32px 32px;
}

[data-theme="light"] .contact-heading {
  color: var(--magenta);
}
[data-theme="light"] .contact-heading-accent {
  color: var(--magenta);
}
[data-theme="light"] .contact-right {
  background: var(--magenta);
}
[data-theme="light"] .contact-statement {
  color: #ffffff;
}
/* Light contact section has inverted colors (white on magenta bg),
   so we override the BaseLayout pill-link defaults here. */
[data-theme="light"] .contact-link {
  color: rgba(255,255,255,0.85);
  border-color: rgba(255,255,255,0.85);
  background: transparent;
}
[data-theme="light"] .contact-link:hover {
  color: var(--magenta);
  background: #ffffff;
  border-color: #ffffff;
}
[data-theme="light"] .contact-link:hover svg {
  stroke: var(--magenta);
}
[data-theme="light"] .contact-divider {
  background: #ffffff;
}

/* Dark and rainbow pill behavior for .contact-link
   is inherited from BaseLayout .pill-link. */

[data-theme="light"] .section-contact::after {
  display: none;
}

[data-theme="rainbow"] .section-contact {
  background: var(--bg);
}
[data-theme="rainbow"] .contact-left {
  background: var(--bg);
}
[data-theme="rainbow"] .contact-right {
  background:
    radial-gradient(circle at 88% 10%, rgba(0,194,255,0.32) 95px, transparent 95px),
    radial-gradient(circle at 60% 7%,  rgba(255,45,120,0.28) 65px, transparent 65px),
    radial-gradient(circle at 28% 15%, rgba(0,232,123,0.30) 95px, transparent 95px),
    radial-gradient(circle at 8% 5%,   rgba(255,214,0,0.26) 40px, transparent 40px),
