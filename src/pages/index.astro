---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/tokens.css';
---

<BaseLayout title="Mae Mendoza — Senior Content Specialist">
  <main id="main-content" style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 60px 32px;">
    <h1 style="font-family: var(--font-heading); font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 700; color: var(--text-primary); line-height: 0.95; margin-bottom: 16px;">
      Mae<br /><span style="color: var(--magenta);">Mendoza</span>
    </h1>
    <p style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 32px;">
      Content and Systems at Scale
    </p>
    <p style="font-family: var(--font-body); font-size: 1rem; color: var(--text-muted); max-width: 420px; line-height: 1.6;">
      Site rebuild in progress. Back soon.
    </p>
  </main>
</BaseLayout>
