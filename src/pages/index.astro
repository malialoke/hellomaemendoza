<script is:inline>
  const rainbowColors = ['var(--magenta)', 'var(--coral)', 'var(--gold)', '#a3e635', '#0891b2', 'var(--violet)'];
  const atlasTabs = document.querySelectorAll('.tab-bar .tab-btn');

  function setTheme(theme) {
    document.documentElement.setAttribute('data-theme', theme);
    document.querySelectorAll('.mode-btn').forEach(btn => {
      const isActive = btn.dataset.theme === theme;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-checked', isActive);
    });
    // Update content-heading color for current tab in rainbow mode
    if (theme === 'rainbow') {
      const activeIndex = Array.from(atlasTabs).findIndex(t => t.classList.contains('active'));
      updateContentHeadingColor(activeIndex);
    } else {
      document.querySelectorAll('.atlas-demo .content-heading').forEach(h => {
        h.style.color = '';
      });
    }
  }

  // Scroll observers — use viewport (root: null) for native scrollbar support
  const sections = document.querySelectorAll('.section');
  const dots = document.querySelectorAll('.nav-dot');

  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const index = Array.from(sections).indexOf(entry.target);
        dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
      }
    });
  }, { root: null, threshold: 0.5 });

  sections.forEach(s => sectionObserver.observe(s));

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { root: null, threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => {
    if (!el.classList.contains('visible')) {
      revealObserver.observe(el);
    }
  });

  // Nav dot click handlers
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const sectionIndex = dot.getAttribute('data-section');
      const target = document.getElementById('section-' + sectionIndex);
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // Atlas demo tab management
  const atlasPanels = document.querySelectorAll('.atlas-demo .tab-panel');

  function updateContentHeadingColor(index) {
    document.querySelectorAll('.atlas-demo .content-heading').forEach(h => {
      h.style.color = rainbowColors[index] || rainbowColors[0];
    });
  }

  function activateTab(index) {
    atlasTabs.forEach((tab, i) => {
      const isActive = i === index;
      tab.classList.toggle('active', isActive);
      tab.setAttribute('aria-selected', isActive);
      tab.setAttribute('tabindex', isActive ? '0' : '-1');
    });
    atlasPanels.forEach((panel, i) => {
      panel.classList.toggle('active', i === index);
    });
    // Update content-heading color to match active tab
    if (document.documentElement.getAttribute('data-theme') === 'rainbow') {
      updateContentHeadingColor(index);
    }
    atlasTabs[index].focus();
  }

  atlasTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => activateTab(i));
  });

  // Theme toggle click handlers
  document.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => setTheme(btn.dataset.theme));
  });

  // Keyboard support for flip cards
  document.querySelectorAll('.flip-card-container').forEach(card => {
    card.setAttribute('tabindex', '0');
    card.setAttribute('role', 'button');
    card.setAttribute('aria-label', card.querySelector('.case-front-title')?.textContent + '. Press Enter to flip.');
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        card.classList.toggle('flipped');
      }
    });
  });

  // Keyboard navigation for atlas tabs
  const tabBar = document.querySelector('.tab-bar');
  if (tabBar) {
    tabBar.addEventListener('keydown', (e) => {
      const current = Array.from(atlasTabs).findIndex(t => t.classList.contains('active'));
      let next = current;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        next = (current + 1) % atlasTabs.length;
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        next = (current - 1 + atlasTabs.length) % atlasTabs.length;
      } else if (e.key === 'Home') {
        e.preventDefault();
        next = 0;
      } else if (e.key === 'End') {
        e.preventDefault();
        next = atlasTabs.length - 1;
      }
      if (next !== current) activateTab(next);
    });
  }

  // Restore saved theme on load (sync toggle button states with BaseLayout's data-theme restore)
  const savedTheme = document.documentElement.getAttribute('data-theme');
  if (savedTheme) setTheme(savedTheme);

  // Save theme to localStorage on toggle
  const origSetTheme = setTheme;
  // Patch to also persist
  document.querySelectorAll('.mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      try { localStorage.setItem('mae-theme', btn.dataset.theme); } catch(e) {}
    });
  });
</script>
</BaseLayout>
