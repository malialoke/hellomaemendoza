  <!-- SECTION 5: CONTACT — Mirrors hero layout -->
  <section class="section section-contact" id="section-4">
    <div class="contact-left">
      <h2 class="contact-heading reveal visible">Let's<br><span class="contact-heading-accent">connect.</span></h2>
    </div>
    <div class="contact-right">
      <div class="contact-divider reveal visible reveal-delay-1"></div>
      <p class="contact-statement reveal visible reveal-delay-2">Find me on LinkedIn to learn more.</p>
      <div class="contact-links reveal visible reveal-delay-3">
        <a class="contact-link pill-link" href="https://linkedin.com/in/maemariamendoza" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          <span class="pill-link-text">LinkedIn</span>
