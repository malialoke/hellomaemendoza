---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AI-Assisted QA Workflow — Mae Mendoza" skipTarget="#main-content">
<style is:inline>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

/* ========== DARK MODE — Aubergine Studio ========== */
[data-theme="dark"] {
  --bg-primary: #0e0b12;
  --bg-secondary: #141018;
  --bg-card: rgba(22, 18, 28, 0.75);
  --text-primary: #f2eff6;
  --text-body: #c8c2d1;
  --text-muted: #8a8296;
  --border-subtle: rgba(255,255,255,0.06);
  --border-hover: rgba(255,255,255,0.14);
  --accent: #e8457a;
  --accent-dim: rgba(232,69,122,0.12);
  --accent-glow: rgba(232,69,122,0.3);
  --green: #7a9e6e;
  --green-dim: rgba(122,158,110,0.12);
  --grain-opacity: 0.025;
  --toggle-bg: rgba(255,255,255,0.08);
  --shadow-card: 0 2px 20px rgba(0,0,0,0.3);
  --ai-color: #7b4dcc;
  --ai-dim: rgba(123,77,204,0.12);
  --human-color: #e8457a;
  --human-dim: rgba(232,69,122,0.12);
  --hybrid-color: #d4762e;
  --hybrid-dim: rgba(212,118,46,0.12);
}

/* ========== LIGHT MODE — Ink & Signal ========== */
[data-theme="light"] {
  --bg-primary: #f7f7f5;
  --bg-secondary: #ffffff;
  --bg-card: rgba(255,255,255,0.92);
  --text-primary: #1a1520;
  --text-body: #4a4358;
  --text-muted: #7a7388;
  --border-subtle: rgba(0,0,0,0.08);
  --border-hover: rgba(0,0,0,0.16);
  --accent: #c23062;
  --accent-dim: rgba(194,48,98,0.08);
  --accent-glow: rgba(194,48,98,0.2);
  --green: #5f8252;
  --green-dim: rgba(95,130,82,0.08);
  --grain-opacity: 0;
  --toggle-bg: rgba(0,0,0,0.06);
  --shadow-card: 0 2px 16px rgba(0,0,0,0.08);
  --ai-color: #6b3fa8;
  --ai-dim: rgba(107,63,168,0.08);
  --human-color: #c23062;
  --human-dim: rgba(194,48,98,0.08);
  --hybrid-color: #b8621e;
  --hybrid-dim: rgba(184,98,30,0.08);
}

/* ========== RAINBOW MODE — Neon Editorial ========== */
[data-theme="rainbow"] {
  --bg-primary: #0a0a0a;
  --bg-secondary: #0e0e0e;
  --bg-card: rgba(14, 14, 14, 0.92);
  --text-primary: #ffffff;
  --text-body: #d4d4d4;
  --text-muted: #999999;
  --border-subtle: rgba(255,255,255,0.08);
  --border-hover: rgba(255,255,255,0.18);
  --accent: #ff2d78;
  --accent-dim: rgba(255,45,120,0.15);
  --accent-glow: rgba(255,45,120,0.4);
  --green: #34d399;
  --green-dim: rgba(52,211,153,0.12);
  --grain-opacity: 0.015;
  --toggle-bg: rgba(255,255,255,0.1);
  --shadow-card: 0 2px 24px rgba(0,0,0,0.5);
  --ai-color: #c4b5fd;
  --ai-dim: rgba(196,181,253,0.15);
  --human-color: #ff2d78;
  --human-dim: rgba(255,45,120,0.15);
  --hybrid-color: #ffb020;
  --hybrid-dim: rgba(255,176,32,0.15);
}

/* ==========================================================
   SECTION TEXTURES — Per-mode, per-section backgrounds
   ========================================================== */

/* ---------- DARK MODE TEXTURES ---------- */
/* Hero: plain black */
/* S01: graph-paper grid */
[data-theme="dark"] section[data-index="1"] {
  background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 32px 32px;
}
/* S02: plain black */
/* S03: graph-paper grid */
[data-theme="dark"] section[data-index="3"] {
  background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 32px 32px;
}
/* S04: graph-paper grid */
[data-theme="dark"] section[data-index="4"] {
  background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 32px 32px;
}
/* S05: magenta polka dots */
[data-theme="dark"] section[data-index="5"] {
  background-image:
    radial-gradient(circle, rgba(232,69,122,0.06) 60px, transparent 60px),
    radial-gradient(circle, rgba(232,69,122,0.06) 60px, transparent 60px);
  background-size: 200px 200px;
  background-position: 30px 20px, 130px 120px;
}
/* S06: graph-paper grid */
[data-theme="dark"] section[data-index="6"] {
  background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 32px 32px;
}

/* ---------- LIGHT MODE TEXTURES ---------- */
/* Hero: graph-paper grid */
[data-theme="light"] .hero {
  background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px) !important;
  background-size: 32px 32px !important;
  background-color: var(--bg-primary) !important;
}
/* S01: plain white */
/* S02: pink polka dots */
[data-theme="light"] section[data-index="2"] {
  background-color: var(--bg-primary);
  background-image:
    radial-gradient(circle, rgba(194,48,98,0.09) 60px, transparent 60px),
    radial-gradient(circle, rgba(194,48,98,0.09) 60px, transparent 60px);
  background-size: 200px 200px;
  background-position: 30px 20px, 130px 120px;
}
/* S03: plain white */
/* S04: graph-paper grid */
[data-theme="light"] section[data-index="4"] {
  background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px);
  background-size: 32px 32px;
}
/* S05: plain white */
/* S06: graph-paper grid */
[data-theme="light"] section[data-index="6"] {
  background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px);
  background-size: 32px 32px;
}

/* ---------- RAINBOW MODE TEXTURES ---------- */
/* Global polka dot base */
[data-theme="rainbow"] body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    radial-gradient(circle, rgba(255,255,255,0.06) 80px, transparent 80px),
    radial-gradient(circle, rgba(255,255,255,0.06) 80px, transparent 80px);
  background-size: 260px 260px;
  background-position: 0 0, 130px 130px;
  pointer-events: none;
  z-index: 0;
}

/* Hero: full rainbow spectrum polka dots */
[data-theme="rainbow"] .hero {
  background:
    radial-gradient(circle at 10% 30%, rgba(255,45,120,0.12) 80px, transparent 80px),
    radial-gradient(circle at 25% 70%, rgba(255,176,32,0.1) 60px, transparent 60px),
    radial-gradient(circle at 45% 20%, rgba(52,211,153,0.1) 70px, transparent 70px),
    radial-gradient(circle at 60% 80%, rgba(34,211,238,0.08) 60px, transparent 60px),
    radial-gradient(circle at 80% 40%, rgba(196,181,253,0.1) 80px, transparent 80px),
    radial-gradient(circle at 90% 10%, rgba(255,45,120,0.08) 50px, transparent 50px),
    radial-gradient(circle at 35% 50%, rgba(255,220,60,0.06) 70px, transparent 70px),
    radial-gradient(circle at 70% 60%, rgba(96,165,250,0.08) 60px, transparent 60px),
    #0a0a0a !important;
}

/* S01: red hue */
[data-theme="rainbow"] section[data-index="1"] {
  background: linear-gradient(160deg, rgba(255,45,120,0.1) 0%, rgba(255,80,60,0.06) 100%);
}
/* S02: orange/gold hue */
[data-theme="rainbow"] section[data-index="2"] {
  background: linear-gradient(160deg, rgba(255,176,32,0.1) 0%, rgba(255,220,60,0.06) 100%);
}
/* S03: green hue */
[data-theme="rainbow"] section[data-index="3"] {
  background: linear-gradient(160deg, rgba(52,211,153,0.1) 0%, rgba(34,211,100,0.05) 100%);
}
/* S04: teal hue */
[data-theme="rainbow"] section[data-index="4"] {
  background: linear-gradient(160deg, rgba(34,211,238,0.1) 0%, rgba(96,165,250,0.06) 100%);
}
/* S05: violet hue */
[data-theme="rainbow"] section[data-index="5"] {
  background: linear-gradient(160deg, rgba(139,92,246,0.1) 0%, rgba(196,181,253,0.06) 100%);
}
/* S06 (takeaway): black/gray polka dots, no color hue */
[data-theme="rainbow"] section[data-index="6"] {
  background: #0a0a0a;
}

/* Rainbow: label-maker text strips */
[data-theme="rainbow"] .section-title {
  display: inline;
  background: rgba(0,0,0,0.7);
  padding: 0.05em 0.25em;
  box-decoration-break: clone;
  -webkit-box-decoration-break: clone;
  line-height: 1.5;
}

/* Rainbow: neon glows */
[data-theme="rainbow"] .pipeline-stage.active .pipeline-card {
  box-shadow: 0 4px 32px rgba(0,0,0,0.4), 0 0 20px color-mix(in srgb, var(--stage-color, #ff2d78) 20%, transparent);
}
[data-theme="rainbow"] .pipeline-stage.active .pipeline-node {
  box-shadow: 0 0 12px color-mix(in srgb, var(--stage-color, #ff2d78) 40%, transparent);
}
[data-theme="rainbow"] .scale-unit.reviewed {
  box-shadow: 0 0 12px rgba(255,45,120,0.5), 0 0 24px rgba(255,45,120,0.2);
}
[data-theme="rainbow"] .content-block.highlight-gap {
  box-shadow: 0 0 12px rgba(255,45,120,0.4), 0 0 24px rgba(255,45,120,0.15);
}
[data-theme="rainbow"] .content-block.highlight-flag {
  box-shadow: 0 0 8px rgba(255,176,32,0.3);
}
[data-theme="rainbow"] .attention-toggle-btn.active {
  box-shadow: 0 0 16px rgba(255,45,120,0.3);
}
[data-theme="rainbow"] .shift-card.ai:hover {
  box-shadow: 0 4px 24px rgba(0,0,0,0.4), 0 0 16px rgba(196,181,253,0.15);
}
[data-theme="rainbow"] .shift-card.human:hover {
  box-shadow: 0 4px 24px rgba(0,0,0,0.4), 0 0 16px rgba(255,45,120,0.15);
}
[data-theme="rainbow"] .shift-divider {
  background: linear-gradient(90deg, transparent, rgba(255,45,120,0.3), rgba(196,181,253,0.3), transparent);
}

/* Rainbow text utility */
.rainbow-text { color: var(--accent); }
[data-theme="rainbow"] .rainbow-text {
  background: linear-gradient(90deg, #ff2d78, #f4845f, #f6c744, #34d399, #22d3ee, #60a5fa, #c4b5fd);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}

/* ========== RESET & BASE ========== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Outfit', sans-serif;
  background: var(--bg-primary);
  color: var(--text-body);
  line-height: 1.65;
  overflow-x: hidden;
  position: relative;
  -webkit-font-smoothing: antialiased;
}
body::before {
  content: '';
  position: fixed;
  inset: 0;
  opacity: var(--grain-opacity);
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  background-size: 256px 256px;
  pointer-events: none;
  z-index: 9998;
}

/* ========== TYPOGRAPHY ========== */
h1, h2, h3 { font-family: 'DM Serif Display', serif; color: var(--text-primary); line-height: 1.15; }
.section-num {
  font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 500;
  letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); display: block; margin-bottom: 0.75rem;
}
.section-title { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 1rem; }
.section-lead { font-size: 1.1rem; color: var(--text-body); max-width: 640px; line-height: 1.7; }
.container { max-width: 960px; margin: 0 auto; padding: 0 2rem; }
section { padding: 6rem 0; position: relative; z-index: 1; }

/* ========== SCROLL REVEAL ========== */
.reveal {
  opacity: 0; transform: translateY(28px);
  transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ========== THEME TOGGLE ========== */
.theme-toggle {
  position: fixed; top: 1.25rem; right: 1.25rem; z-index: 9999;
  display: flex; align-items: center; background: var(--toggle-bg);
  border: 1px solid var(--border-subtle); border-radius: 20px; padding: 3px;
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
}
.theme-toggle-option {
  width: 26px; height: 26px; border-radius: 50%; border: none; background: transparent;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: var(--text-muted); transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); padding: 0;
}
.theme-toggle-option.active {
  background: var(--text-primary); color: var(--bg-primary); box-shadow: 0 1px 8px rgba(0,0,0,0.2);
}
[data-theme="rainbow"] .theme-toggle-option[data-theme="rainbow"].active {
  background: linear-gradient(135deg, #ff2d78, #ffb020, #34d399, #22d3ee, #c4b5fd); color: #0a0a0a;
}

/* ========== NAV DOTS ========== */
.nav-dots { position: fixed; right: 1.25rem; top: 50%; transform: translateY(-50%); z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
.nav-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border-subtle); border: none; cursor: pointer; transition: all 0.3s; padding: 0; }
.nav-dot:hover { background: var(--text-muted); }
.nav-dot.active { background: var(--accent); box-shadow: 0 0 8px var(--accent-glow); }
[data-theme="rainbow"] .nav-dot.active { background: #ff2d78; box-shadow: 0 0 12px rgba(255,45,120,0.6); }

/* ========== HERO (left-aligned, matching Dual Build) ========== */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--bg-primary);
}
.hero-content {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 2rem;
  /* LEFT-ALIGNED like Dual Build */
}
.hero-eyebrow {
  font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 500;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem;
}
.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(2.8rem, 6vw, 4.2rem);
  line-height: 1.08;
  margin-bottom: 1.5rem;
  max-width: 780px;
}
.hero h1 em { font-style: italic; color: var(--accent); }
[data-theme="rainbow"] .hero h1 em {
  background: linear-gradient(90deg, #ff2d78, #ffb020, #34d399);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
[data-theme="rainbow"] .hero h1 { text-shadow: 0 0 80px rgba(255,45,120,0.2); }
.hero-sub {
  font-size: 1.15rem; color: var(--text-body); max-width: 560px; line-height: 1.7;
}

/* ========== SECTION 01 — SCALE GRID ========== */
.scale-grid { display: grid; grid-template-columns: repeat(auto-fill, 28px); gap: 4px; max-width: 640px; margin: 2.5rem 0; }
.scale-unit { width: 28px; height: 28px; border-radius: 4px; background: var(--border-subtle); transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1); }
.scale-unit.reviewed { background: var(--accent); box-shadow: 0 0 8px var(--accent-glow); }
.scale-grid-legend { display: flex; gap: 1.5rem; margin-top: 1rem; flex-wrap: wrap; }
.scale-grid-legend-item { display: flex; align-items: center; gap: 0.5rem; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.05em; color: var(--text-muted); }
.scale-grid-legend-swatch { width: 12px; height: 12px; border-radius: 3px; }

/* ========== SECTION 02 — THESIS ========== */
.thesis-section { min-height: 80vh; display: flex; flex-direction: column; justify-content: center; align-items: center; }
.thesis-statement {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(3.2rem, 10vw, 7rem);
  line-height: 0.95; color: var(--text-primary); text-align: center;
  max-width: 900px; margin: 0 auto 2.5rem; letter-spacing: -0.02em;
}
.thesis-keyword { color: var(--accent); }
[data-theme="rainbow"] .thesis-keyword {
  background: linear-gradient(90deg, #ff2d78, #ffb020, #34d399, #22d3ee, #c4b5fd);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
[data-theme="dark"] .thesis-keyword { text-shadow: 0 0 60px var(--accent-glow), 0 0 120px rgba(232,69,122,0.15); }
[data-theme="rainbow"] .thesis-statement { text-shadow: 0 0 100px rgba(255,45,120,0.15), 0 0 200px rgba(196,181,253,0.1); }
.thesis-body { text-align: center; font-size: 1.15rem; color: var(--text-body); max-width: 540px; margin: 0 auto; line-height: 1.7; }

/* ========== SECTION 03 — PIPELINE ========== */
.pipeline { position: relative; margin: 3rem 0; }
.pipeline-line { position: absolute; left: 24px; top: 0; bottom: 0; width: 2px; background: var(--border-subtle); z-index: 0; }
.pipeline-line-fill { position: absolute; left: 0; top: 0; width: 100%; height: 0%; background: var(--accent); transition: height 1.2s cubic-bezier(0.22, 1, 0.36, 1); border-radius: 1px; }
[data-theme="rainbow"] .pipeline-line-fill { background: linear-gradient(180deg, #ff2d78, #ffb020, #34d399, #c4b5fd); }
.pipeline-stage { position: relative; z-index: 1; padding-left: 64px; margin-bottom: 1rem; cursor: pointer; }
.pipeline-node {
  position: absolute; left: 12px; top: 14px; width: 24px; height: 24px; border-radius: 50%;
  border: 2px solid var(--border-subtle); background: var(--bg-primary);
  display: flex; align-items: center; justify-content: center;
  font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; font-weight: 500;
  color: var(--text-muted); transition: all 0.4s; z-index: 2;
}
.pipeline-stage.active .pipeline-node, .pipeline-stage.passed .pipeline-node {
  border-color: var(--stage-color, var(--accent)); background: var(--stage-color, var(--accent)); color: #fff;
}
.pipeline-card {
  background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: 12px;
  padding: 1.25rem 1.5rem; transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
}
.pipeline-stage:hover .pipeline-card { border-color: var(--border-hover); }
.pipeline-stage.active .pipeline-card { border-color: var(--stage-color, var(--border-hover)); box-shadow: var(--shadow-card); }
.pipeline-card-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
.pipeline-card-title-group { flex: 1; display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
.pipeline-card-title { font-family: 'DM Serif Display', serif; font-size: 1.35rem; color: var(--text-primary); }
.pipeline-card-role {
  font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 20px;
  background: var(--stage-dim, var(--accent-dim)); color: var(--stage-color, var(--accent)); white-space: nowrap;
}
.pipeline-card-toggle {
  width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--border-subtle);
  background: transparent; color: var(--text-muted); display: flex; align-items: center;
  justify-content: center; font-size: 0.8rem; transition: all 0.3s; flex-shrink: 0; cursor: pointer;
}
.pipeline-stage.active .pipeline-card-toggle { transform: rotate(45deg); border-color: var(--stage-color, var(--accent)); color: var(--stage-color, var(--accent)); }
.pipeline-card-body { max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s; opacity: 0; }
.pipeline-stage.active .pipeline-card-body { max-height: 400px; opacity: 1; }
.pipeline-card-body-inner { padding-top: 1rem; margin-top: 1rem; border-top: 1px solid var(--border-subtle); }
.pipeline-task-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.pipeline-task { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.9rem; color: var(--text-body); line-height: 1.5; }
.pipeline-task-marker { width: 6px; height: 6px; border-radius: 50%; background: var(--stage-color, var(--accent)); flex-shrink: 0; margin-top: 0.5rem; }

/* ========== SECTION 04 — SHIFT CARDS ========== */
.shift-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 2.5rem 0; }
@media (max-width: 700px) { .shift-grid { grid-template-columns: 1fr; } }
.shift-card {
  background: var(--bg-card); border: 1px solid var(--border-subtle); border-radius: 12px;
  padding: 1.25rem 1.5rem; display: flex; align-items: flex-start; gap: 1rem;
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); transition: all 0.4s;
}
.shift-card:hover { border-color: var(--border-hover); box-shadow: var(--shadow-card); }
.shift-card-icon {
  width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center;
