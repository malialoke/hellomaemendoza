<script is:inline>
// THEME TOGGLE
const html = document.documentElement;
const themeButtons = document.querySelectorAll('.theme-toggle-option');
function setTheme(t) {
  html.dataset.theme = t;
  themeButtons.forEach(b => b.classList.toggle('active', b.dataset.theme === t));
  themeButtons.forEach(b => {
    b.setAttribute('aria-checked', b.dataset.theme === t ? 'true' : 'false');
  });
  try { localStorage.setItem('mae-theme', t); } catch(e) {}
}
themeButtons.forEach(b => b.addEventListener('click', () => setTheme(b.dataset.theme)));
// Restore saved theme
try {
  const saved = localStorage.getItem('mae-theme');
  if (saved) setTheme(saved);
} catch(e) {}
// Theme defaults to whatever data-theme is set on <html>.

// SCROLL REVEAL
const revealObs = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }), { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

// NAV DOTS
const sections = document.querySelectorAll('section[data-index]');
const dots = document.querySelectorAll('.nav-dot');
dots.forEach(d => d.addEventListener('click', () => sections[parseInt(d.dataset.section)]?.scrollIntoView({ behavior: 'smooth' })));
const dotObs = new IntersectionObserver(es => es.forEach(e => {
  if (e.isIntersecting) { dots.forEach(d => d.classList.remove('active')); document.querySelector(`.nav-dot[data-section="${e.target.dataset.index}"]`)?.classList.add('active'); }
}), { threshold: 0.35 });
sections.forEach(s => dotObs.observe(s));

// SCALE GRID
const sg = document.getElementById('scaleGrid');
if (sg) { const rev = [3,11,27,42,58,71,89,104]; for (let i=0;i<120;i++) { const b=document.createElement('div'); b.className='scale-unit'; if(rev.includes(i))b.classList.add('reviewed'); sg.appendChild(b); } }

// PIPELINE — rainbow mode recolors stages to ROYGBIV order
const stages = document.querySelectorAll('.pipeline-stage');
const pf = document.getElementById('pipelineFill');
const rainbowStageColors = ['#ff2d78','#ffb020','#34d399','#c4b5fd']; // red, orange, green, violet

function applyRainbowColors() {
  const isRainbow = html.dataset.theme === 'rainbow';
  stages.forEach((s, i) => {
    if (isRainbow) {
      s.style.setProperty('--stage-color', rainbowStageColors[i]);
      s.style.setProperty('--stage-dim', rainbowStageColors[i] + '22');
    } else {
      s.style.removeProperty('--stage-color');
      s.style.removeProperty('--stage-dim');
    }
  });
}

// Re-apply on theme change
const origSetTheme = setTheme;
// Patch setTheme to also update rainbow colors
const _origBtnHandlers = [];
themeButtons.forEach(b => {
  b.removeEventListener('click', () => {}); // can't remove anonymous, so we re-bind
});
// Re-bind with rainbow color application
themeButtons.forEach(b => {
  const handler = () => { setTheme(b.dataset.theme); applyRainbowColors(); };
  b.addEventListener('click', handler);
});
applyRainbowColors();

function openStage(s) {
  const was = s.classList.contains('active');
  stages.forEach(x => { x.classList.remove('active','passed'); x.setAttribute('aria-expanded','false'); });
  if (!was) {
    s.classList.add('active'); s.setAttribute('aria-expanded','true');
    const idx = parseInt(s.dataset.stage);
    stages.forEach(x => { if (parseInt(x.dataset.stage) < idx) x.classList.add('passed'); });
    if (pf) pf.style.height = (idx / stages.length * 100) + '%';
  } else { if (pf) pf.style.height = '0%'; }
}
stages.forEach(s => { s.addEventListener('click', () => openStage(s)); s.addEventListener('keydown', e => { if(e.key==='Enter'||e.key===' '){e.preventDefault();openStage(s);} }); s.setAttribute('tabindex','0'); s.setAttribute('role','button'); s.setAttribute('aria-expanded','false'); });
const po = new IntersectionObserver(es => es.forEach(e => { if(e.isIntersecting){setTimeout(()=>openStage(stages[0]),600);po.disconnect();} }), {threshold:0.25});
const pe = document.getElementById('pipeline'); if(pe) po.observe(pe);

// ATTENTION DEMO
document.querySelectorAll('.attention-toggle-btn').forEach(btn => btn.addEventListener('click', () => {
  document.querySelectorAll('.attention-toggle-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.attention-view').forEach(v=>v.classList.remove('active'));
  btn.classList.add('active');
  document.querySelector(`.attention-view[data-view="${btn.dataset.view}"]`)?.classList.add('active');
}));
const ww=document.getElementById('wallWithout'), wv=document.getElementById('wallWith');
const gaps=[5,12,23,34,51,67], flags=[8,19,31,44,56,72];
for(let i=0;i<80;i++){
  const a=document.createElement('div'); a.className='content-block'; ww?.appendChild(a);
  const b=document.createElement('div'); b.className='content-block';
  if(gaps.includes(i))b.classList.add('highlight-gap'); else if(flags.includes(i))b.classList.add('highlight-flag'); else b.classList.add('highlight-ok');
  wv?.appendChild(b);
}

// Watch for theme changes via MutationObserver to reapply rainbow colors
new MutationObserver(() => applyRainbowColors()).observe(html, { attributes: true, attributeFilter: ['data-theme'] });
// Sync toggle button states with restored theme
const restoredTheme = document.documentElement.getAttribute('data-theme');
if (restoredTheme) {
  document.querySelectorAll('.theme-toggle-option').forEach(b => {
    b.classList.toggle('active', b.dataset.theme === restoredTheme);
    b.setAttribute('aria-checked', b.dataset.theme === restoredTheme ? 'true' : 'false');
  });
}
