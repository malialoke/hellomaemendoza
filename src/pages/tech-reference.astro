---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Technical Reference — Mae Mendoza" skipTarget="#classification" defaultTheme="light">
<style is:inline>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

:root{
  --bg-primary:#FAFAF7;--bg-secondary:#fff;--bg-glass:rgba(0,0,0,0.02);--bg-warm:rgba(180,140,80,0.04);
  --text-primary:#1C1917;--text-body:#44403C;--text-muted:#78716C;
  --border-subtle:rgba(0,0,0,0.08);--border-hover:rgba(0,0,0,0.14);
  --teal:#1A8A8A;--teal-dim:rgba(26,138,138,0.08);
  --sky:#3B9EBF;--sky-dim:rgba(59,158,191,0.07);
  --burnt:#C4652A;--burnt-dim:rgba(196,101,42,0.07);
  --gold:#B08D3E;--gold-dim:rgba(176,141,62,0.07);
  --sand:#A69882;--sand-dim:rgba(166,152,130,0.06);
  --shadow-card:0 1px 8px rgba(0,0,0,0.04);
}

*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;font-size:18px}
body{font-family:'Outfit',sans-serif;background:var(--bg-primary);color:var(--text-body);-webkit-font-smoothing:antialiased;line-height:1.7}

.back-link{position:fixed;top:24px;left:24px;z-index:200;font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;padding:8px 14px;border-radius:30px;background:var(--bg-secondary);border:1px solid var(--border-subtle);transition:all .3s}
.back-link:hover{color:var(--teal);border-color:var(--border-hover)}
.back-link:focus-visible{outline:2px solid var(--teal);outline-offset:2px}
.sample-label{position:fixed;top:24px;right:24px;z-index:200;font-family:'JetBrains Mono',monospace;font-size:.56rem;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);opacity:.5;padding:8px 14px;border-radius:30px;background:var(--bg-secondary);border:1px solid var(--border-subtle)}

.doc{max-width:660px;margin:0 auto;padding:110px clamp(24px,6vw,48px) 100px}

.doc-header{margin-bottom:56px;padding-bottom:32px;border-bottom:1px solid var(--border-subtle)}
.doc-eyebrow{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--teal);margin-bottom:20px}
.doc-title{font-family:'DM Serif Display',serif;font-size:clamp(1.7rem,3.2vw,2.4rem);color:var(--text-primary);line-height:1.2;margin-bottom:16px}
.doc-subtitle{font-size:1rem;color:var(--text-muted);font-weight:300;line-height:1.6;max-width:520px;margin-bottom:20px}
.doc-meta{font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:.06em;color:var(--text-muted);display:flex;gap:20px;flex-wrap:wrap}
.doc-meta span{padding:4px 10px;border-radius:4px;background:var(--bg-glass);border:1px solid var(--border-subtle)}

.doc-toc{margin-bottom:52px;padding:24px 28px;border-radius:10px;background:var(--bg-secondary);border:1px solid var(--border-subtle);box-shadow:var(--shadow-card)}
.doc-toc-label{font-family:'JetBrains Mono',monospace;font-size:.56rem;letter-spacing:.14em;text-transform:uppercase;color:var(--sand);margin-bottom:14px}
.doc-toc a{display:block;font-size:.88rem;color:var(--text-body);text-decoration:none;padding:6px 0;border-bottom:1px solid rgba(0,0,0,0.04);transition:color .2s}
.doc-toc a:last-child{border-bottom:none}
.doc-toc a:hover{color:var(--teal)}
.doc-toc a span{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--sand);margin-right:10px}

.doc-section{margin-bottom:56px}
.doc-section-header{margin-bottom:24px;padding-bottom:14px;border-bottom:1px solid var(--border-subtle)}
.doc-section-header .sec-num{font-family:'JetBrains Mono',monospace;font-size:.56rem;letter-spacing:.14em;text-transform:uppercase;color:var(--teal);display:block;margin-bottom:6px}
.doc-section-title{font-family:'DM Serif Display',serif;font-size:1.3rem;color:var(--text-primary);line-height:1.3}
.doc-p{font-size:.9rem;color:var(--text-body);line-height:1.75;margin-bottom:16px}
.doc-p strong{color:var(--text-primary);font-weight:600}

.tier-block{padding:18px 22px;background:var(--bg-secondary);border-radius:0 10px 10px 0;margin:16px 0;font-size:.86rem;color:var(--text-body);line-height:1.7;box-shadow:var(--shadow-card);border:1px solid var(--border-subtle);border-left:3px solid var(--teal)}
.tier-block strong{color:var(--text-primary);font-weight:600}
.tier-block.restricted{border-left-color:var(--burnt)}
.tier-block.confidential{border-left-color:var(--gold)}
.tier-block.internal{border-left-color:var(--teal)}
.tier-block.public{border-left-color:var(--sand)}
.ref{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--text-muted);background:var(--bg-glass);padding:2px 6px;border-radius:3px;border:1px solid var(--border-subtle)}
.action{display:block;margin-top:10px;padding-top:10px;border-top:1px dashed rgba(0,0,0,0.06);font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.03em;color:var(--teal)}

.step{margin-bottom:20px;padding:18px 22px;border-radius:10px;background:var(--bg-secondary);border:1px solid var(--border-subtle);box-shadow:var(--shadow-card)}
.step-label{font-family:'JetBrains Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sky);margin-bottom:6px}
.step p{font-size:.88rem;color:var(--text-body);line-height:1.7}
.step p strong{color:var(--text-primary)}

.cat-grid{display:grid;grid-template-columns:1fr;gap:12px;margin:16px 0}
.cat-block{padding:16px 20px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border-subtle);box-shadow:var(--shadow-card);font-size:.86rem;color:var(--text-body);line-height:1.65;display:grid;grid-template-columns:auto 1fr;gap:14px;align-items:start}
.cat-block strong{color:var(--text-primary);font-weight:600}
.cat-badge{font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;padding:4px 10px;border-radius:5px;white-space:nowrap;font-weight:500;margin-top:2px}
.cat-badge.cat-a{background:var(--burnt-dim);color:var(--burnt)}
.cat-badge.cat-b{background:var(--gold-dim);color:var(--gold)}
.cat-badge.cat-c{background:var(--sand-dim);color:var(--sand)}
.cat-time{font-family:'JetBrains Mono',monospace;font-size:.78rem;color:var(--sky);font-weight:500}

.doc-callout{margin:24px 0;padding:18px 22px;border-radius:10px;background:var(--teal-dim);border:1px solid rgba(26,138,138,0.12);font-size:.86rem;color:var(--text-body);line-height:1.65}
.doc-callout strong{color:var(--teal)}

.ownership-grid{display:grid;grid-template-columns:1fr;gap:14px;margin:20px 0}
.own-card{padding:18px 22px;background:var(--bg-secondary);border-radius:10px;border:1px solid var(--border-subtle);box-shadow:var(--shadow-card);display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:start}
.own-badge{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;padding:6px 12px;border-radius:6px;white-space:nowrap;font-weight:500;margin-top:2px}
.own-badge.owner{background:var(--teal-dim);color:var(--teal)}
.own-badge.steward{background:var(--sky-dim);color:var(--sky)}
.own-badge.custodian{background:var(--gold-dim);color:var(--gold)}
.own-card h4{font-weight:600;font-size:.92rem;color:var(--text-primary);margin-bottom:4px}
.own-card p{font-size:.84rem;color:var(--text-muted);line-height:1.6}

.doc-footer{margin-top:64px;padding-top:28px;border-top:1px solid var(--border-subtle);font-family:'JetBrains Mono',monospace;font-size:.58rem;color:var(--text-muted);letter-spacing:.06em;line-height:1.8}

@media(max-width:768px){
  html{font-size:16px}
  .doc{padding:80px 20px 60px}
  .back-link{top:16px;left:16px;font-size:.6rem;padding:6px 10px}
  .sample-label{top:16px;right:16px;font-size:.5rem;padding:6px 10px}
  .doc-meta{flex-direction:column;gap:6px}
  .cat-block,.own-card{grid-template-columns:1fr}
}
.skip-link{position:absolute;top:-100px;left:16px;background:var(--teal);color:#fff;padding:8px 16px;border-radius:4px;z-index:9999;font-family:'JetBrains Mono',monospace;font-size:.75rem;text-decoration:none}
.skip-link:focus{top:16px}
@media(prefers-reduced-motion:reduce){html{scroll-behavior:auto}}
@media print{.back-link,.sample-label{display:none}.doc{padding:40px 20px}body{background:#fff}}
</style>


<a href="#classification" class="skip-link">Skip to content</a>
<a href="/audience-adaptation#deliverables" class="back-link">&larr; Back to case study</a>
<div class="sample-label">Portfolio sample &middot; Arcline is fictional</div>

<article class="doc">
  <header class="doc-header">
    <div class="doc-eyebrow">Arcline &middot; Data Governance Council</div>
    <h1 class="doc-title">Classification &amp; Incident Response Quick Reference</h1>
    <p class="doc-subtitle">The practitioner reference for the data governance framework. Tier definitions, response protocols, ownership model.</p>
    <div class="doc-meta">
      <span>Version 2.4</span>
      <span>Updated Q2 2025</span>
      <span>Stewards &amp; Practitioners</span>
    </div>
  </header>

  <nav class="doc-toc" aria-label="Table of contents">
    <div class="doc-toc-label">Contents</div>
    <a href="#classification"><span>01</span> Data Classification: Four Tiers</a>
    <a href="#response"><span>02</span> Incident Response: What You Do and When</a>
    <a href="#ownership"><span>03</span> Ownership and Escalation</a>
  </nav>

  <section class="doc-section" id="classification">
    <div class="doc-section-header">
      <span class="sec-num">Section 01</span>
      <h2 class="doc-section-title">Data Classification: Four Tiers</h2>
    </div>
    <p class="doc-p">Classify all data assets by sensitivity, regulatory exposure, and business impact of unauthorized disclosure. The tier determines protections, response timelines, and the accountability chain.</p>

    <div class="tier-block restricted">
      <strong>Tier 1 — Restricted.</strong> Regulatory mandate <span class="ref">GDPR Art. 9</span> <span class="ref">CCPA</span> <span class="ref">HIPAA PHI</span> or contractual liquidated damages. PII above re-identification threshold. Breach: mandatory notification within 72 hours.
      <span class="action">Your action → Flag for DDO classification approval. Do not reclassify without DGC sign-off.</span>
    </div>
    <div class="tier-block confidential">
      <strong>Tier 2 — Confidential.</strong> Material business harm, no mandatory notification. Pre-release financials, vendor MFN terms, pre-board audit findings. Access: named roles per RBAC matrix <span class="ref">&sect;4.1</span>.
      <span class="action">Your action → Maintain access list, quarterly review, process sharing via DSA.</span>
    </div>
    <div class="tier-block internal">
      <strong>Tier 3 — Internal.</strong> Low risk. Departmental docs, internal comms (no litigation hold), de-identified datasets <span class="ref">45 CFR &sect;164.514(b)</span>. Baseline AES-256.
      <span class="action">Your action → Catalog maintenance. Reclassify upward if context changes.</span>
    </div>
    <div class="tier-block public">
      <strong>Tier 4 — Public.</strong> Cleared per <span class="ref">&sect;6.3</span>. Reclassification to restricted requires DGC approval + retroactive audit.
    </div>
  </section>

  <section class="doc-section" id="response">
    <div class="doc-section-header">
      <span class="sec-num">Section 02</span>
      <h2 class="doc-section-title">Incident Response: What You Do and When</h2>
    </div>

    <div class="step">
      <div class="step-label">Step 1 — Report</div>
      <p>File a Data Incident Report (DIR) in the GRC platform. Deadline: <strong>4 hours from discovery.</strong></p>
    </div>
    <div class="step">
      <div class="step-label">Step 2 — Notification</div>
      <p>The DIR auto-notifies the DGC duty officer, your Domain Data Owner (DDO), and the Information Security Incident Response Team (ISIRT).</p>
    </div>
    <div class="step">
      <div class="step-label">Step 3 — Triage</div>
      <p>DGC duty officer classifies within <strong>2 hours</strong> of DIR receipt:</p>
    </div>

    <div class="cat-grid">
      <div class="cat-block">
        <span class="cat-badge cat-a">Cat A</span>
        <div><strong>Confirmed Tier 1, external exposure.</strong> Full breach protocol <span class="ref">&sect;5.3</span>. Executive briefing within <span class="cat-time">6 hours</span>.</div>
      </div>
      <div class="cat-block">
        <span class="cat-badge cat-b">Cat B</span>
        <div><strong>Confirmed Tier 2 or Tier 1 contained.</strong> DDO-led response <span class="ref">&sect;5.4</span>. Target resolution: <span class="cat-time">48 hours</span>.</div>
      </div>
      <div class="cat-block">
        <span class="cat-badge cat-c">Cat C</span>
        <div><strong>Suspected, unconfirmed.</strong> ISIRT investigation. <span class="cat-time">5 business days</span> to classify or close.</div>
      </div>
    </div>

    <div class="doc-callout"><strong>Unsure if it qualifies?</strong> File the DIR. Under-reporting is the bigger risk.</div>
  </section>

  <section class="doc-section" id="ownership">
    <div class="doc-section-header">
      <span class="sec-num">Section 03</span>
      <h2 class="doc-section-title">Ownership and Escalation</h2>
    </div>
    <p class="doc-p">Every data domain has three defined roles. Governance decisions flow from Owner to Steward to Custodian. Incident reports flow in the opposite direction.</p>

    <div class="ownership-grid">
      <div class="own-card">
        <span class="own-badge owner">Owner</span>
        <div>
          <h4>Domain Owner (VP-level)</h4>
          <p>Sets classification policy. Accountable for regulatory compliance within their domain. Makes the final call during a Category A incident.</p>
        </div>
      </div>
      <div class="own-card">
        <span class="own-badge steward">Steward</span>
        <div>
          <h4>Data Steward (day-to-day governance)</h4>
          <p>Your first point of contact for any data question. Maintains access lists and runs quarterly reviews. Coordinates with legal as needed.</p>
        </div>
      </div>
      <div class="own-card">
        <span class="own-badge custodian">Custodian</span>
        <div>
          <h4>Custodians (technical implementation)</h4>
          <p>Implements controls and manages encryption. Handles access provisioning based on steward and owner directives.</p>
        </div>
      </div>
    </div>

    <p class="doc-p" style="margin-top:20px">For most day-to-day questions, <strong>your steward is your first contact.</strong> Escalate to the Domain Owner for classification disputes or incidents that may cross domain boundaries.</p>
  </section>

  <footer class="doc-footer">
    Arcline &middot; Data Governance Framework v2.4 &middot; Quick Reference<br>
    Full documentation available on the governance wiki
  </footer>
</article>

</BaseLayout>
