---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Audience Adaptation — Mae Mendoza"
  description="One governance framework, three audiences. How structure, pacing, and entry points change when the information doesn't."
  canonicalPath="/audience-adaptation"
  skipTarget="#section-hero"
>
<style is:inline>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

/* ========== DARK MODE ========== */
[data-theme="dark"]{
  --bg-primary:#0e0b12;--bg-secondary:#141018;--bg-card:rgba(22,18,28,0.75);--bg-glass:rgba(255,255,255,0.03);
  --text-primary:#f2eff6;--text-body:#c8c2d1;--text-muted:#8a8296;
  --border-subtle:rgba(255,255,255,0.06);--border-hover:rgba(255,255,255,0.14);
  --accent:#e8457a;--accent-dim:rgba(232,69,122,0.12);--accent-glow:rgba(232,69,122,0.3);
  --grain-opacity:0.025;--toggle-bg:rgba(255,255,255,0.08);--shadow-card:0 2px 20px rgba(0,0,0,0.3);
  --doc-bg:rgba(30,26,38,0.9);--doc-border:rgba(255,255,255,0.08);--doc-header:rgba(232,69,122,0.06);
  --tab-inactive-bg:rgba(255,255,255,0.04);--tab-inactive-text:#8a8296;
  --source-ref:rgba(232,69,122,0.15);
}
/* ========== LIGHT MODE ========== */
[data-theme="light"]{
  --bg-primary:#f7f7f5;--bg-secondary:#ffffff;--bg-card:rgba(255,255,255,0.92);--bg-glass:rgba(0,0,0,0.02);
  --text-primary:#1a1520;--text-body:#4a4358;--text-muted:#7a7388;
  --border-subtle:rgba(0,0,0,0.08);--border-hover:rgba(0,0,0,0.16);
  --accent:#c23062;--accent-dim:rgba(194,48,98,0.08);--accent-glow:rgba(194,48,98,0.2);
  --grain-opacity:0;--toggle-bg:rgba(0,0,0,0.06);--shadow-card:0 2px 16px rgba(0,0,0,0.08);
  --doc-bg:#ffffff;--doc-border:rgba(0,0,0,0.1);--doc-header:rgba(194,48,98,0.04);
  --tab-inactive-bg:rgba(0,0,0,0.03);--tab-inactive-text:#7a7388;
  --source-ref:rgba(194,48,98,0.06);
}
/* ========== RAINBOW MODE ========== */
[data-theme="rainbow"]{
  --bg-primary:#0a0a0a;--bg-secondary:#0e0e0e;--bg-card:rgba(14,14,14,0.92);--bg-glass:rgba(255,255,255,0.04);
  --text-primary:#ffffff;--text-body:#d4d4d4;--text-muted:#999999;
  --border-subtle:rgba(255,255,255,0.08);--border-hover:rgba(255,255,255,0.18);
  --accent:#ff2d78;--accent-dim:rgba(255,45,120,0.12);--accent-glow:rgba(255,45,120,0.4);
  --grain-opacity:0.025;--toggle-bg:rgba(255,255,255,0.08);--shadow-card:0 2px 24px rgba(0,0,0,0.4);
  --doc-bg:rgba(14,14,14,0.95);--doc-border:rgba(255,255,255,0.1);--doc-header:rgba(255,45,120,0.08);
  --tab-inactive-bg:rgba(255,255,255,0.06);--tab-inactive-text:#999999;
  --source-ref:rgba(255,45,120,0.1);
}

/* ========== BASE ========== */
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;font-size:18px}
body{font-family:'Outfit',sans-serif;background:var(--bg-primary);color:var(--text-body);overflow-x:hidden;-webkit-font-smoothing:antialiased;transition:background .4s,color .4s;line-height:1.65}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");opacity:var(--grain-opacity);pointer-events:none;z-index:9999}
[data-theme="rainbow"] body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    radial-gradient(circle,rgba(255,45,120,0.05) 60px,transparent 60px),
    radial-gradient(circle,rgba(0,232,123,0.04) 45px,transparent 45px),
    radial-gradient(circle,rgba(0,194,255,0.05) 55px,transparent 55px),
    radial-gradient(circle,rgba(255,214,0,0.04) 40px,transparent 40px),
    radial-gradient(circle,rgba(168,85,247,0.05) 50px,transparent 50px);
  background-size:320px 320px,260px 280px,280px 300px,240px 260px,300px 280px;
  background-position:40px 30px,180px 160px,80px 240px,220px 60px,140px 140px}

/* ========== CHROME ========== */
.theme-toggle{position:fixed;top:24px;right:24px;z-index:200;display:flex;gap:0;background:var(--bg-card);backdrop-filter:blur(16px);border:1px solid var(--border-subtle);border-radius:40px;padding:4px;transition:all .3s}
.theme-toggle-option{background:none;border:none;cursor:pointer;padding:7px 12px;border-radius:30px;font-size:.82rem;line-height:1;color:var(--text-muted);transition:all .3s}
.theme-toggle-option.active{background:var(--accent);color:#fff}
.theme-toggle-option:hover:not(.active){color:var(--text-primary)}
[data-theme="rainbow"] .theme-toggle-option.active{background:linear-gradient(135deg,#ff2d78,#ff6b35,#ffd600,#00e87b,#00c2ff,#a855f7)}
.back-link{position:fixed;top:24px;left:24px;z-index:200;font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;padding:8px 14px;border-radius:30px;background:var(--bg-card);backdrop-filter:blur(16px);border:1px solid var(--border-subtle);transition:all .3s}
.back-link:hover{color:var(--accent);border-color:var(--border-hover)}
.nav-dots{position:fixed;right:24px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:12px;z-index:100}
.nav-dot{width:8px;height:8px;border-radius:50%;background:var(--border-subtle);cursor:pointer;transition:all .3s;border:none;padding:0}
.nav-dot.active{background:var(--accent);box-shadow:0 0 8px var(--accent-glow)}
.nav-dot:hover{background:var(--text-muted)}

/* ========== SECTIONS ========== */
section{min-height:100vh;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:100px clamp(28px,8vw,120px);position:relative;z-index:1}
.container{max-width:960px;width:100%;margin:0 auto}
.section-num{font-family:'JetBrains Mono',monospace;font-size:.7rem;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:var(--accent);margin-bottom:18px}
.section-title{font-family:'DM Serif Display',serif;font-size:clamp(1.8rem,3.6vw,2.6rem);color:var(--text-primary);line-height:1.18;max-width:720px;margin-bottom:20px}
.section-title em{font-style:italic;color:var(--accent)}
.section-lead{font-size:clamp(1rem,1.3vw,1.1rem);color:var(--text-muted);max-width:620px;line-height:1.7;font-weight:300}
[data-theme="rainbow"] .section-title{background:rgba(0,0,0,0.7);display:inline;padding:4px 10px;box-decoration-break:clone;-webkit-box-decoration-break:clone;line-height:1.5}
[data-theme="rainbow"] .section-num{display:block}
[data-theme="rainbow"] .section-title em{background:linear-gradient(135deg,#ff2d78,#ff6b35,#ffd600,#00e87b,#00c2ff,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

/* ========== HERO ========== */
.hero{align-items:center;min-height:100vh}
.hero-eyebrow{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--accent);margin-bottom:28px;opacity:0;animation:fadeUp .8s ease forwards .3s}
.hero h1{font-family:'DM Serif Display',serif;font-size:clamp(2.8rem,6vw,4.2rem);line-height:1.1;color:var(--text-primary);opacity:0;animation:fadeUp .8s ease forwards .5s}
.hero h1 em{font-style:italic;color:var(--accent)}
[data-theme="rainbow"] .hero h1{background:none;display:block;padding:0}
[data-theme="rainbow"] .hero h1 em{background:linear-gradient(135deg,#ff2d78,#ff6b35,#ffd600,#00e87b,#00c2ff,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{margin-top:32px;font-size:clamp(1.05rem,1.6vw,1.15rem);max-width:680px;font-weight:300;color:var(--text-muted);line-height:1.7;opacity:0;animation:fadeUp .8s ease forwards .7s}
.hero-meta{margin-top:52px;display:flex;gap:28px;flex-wrap:wrap;opacity:0;animation:fadeUp .8s ease forwards .9s}
.hero-meta span{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.1em;color:var(--text-muted)}
.scroll-cue{position:absolute;bottom:44px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadeUp .8s ease forwards 1.2s}
.scroll-cue span{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--text-muted)}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,var(--accent),transparent);animation:pulse 2s ease-in-out infinite}

/* ========== REVEAL ========== */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s cubic-bezier(0.22,1,0.36,1),transform .7s cubic-bezier(0.22,1,0.36,1)}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ========== SOURCE DOC ========== */
.source-doc{max-width:860px;margin-top:40px;border:1px solid var(--doc-border);border-radius:12px;overflow:hidden;background:var(--doc-bg);box-shadow:var(--shadow-card)}
.source-header{padding:12px 20px;background:var(--doc-header);border-bottom:1px solid var(--doc-border);display:flex;align-items:center;gap:10px}
.source-header .dot{width:8px;height:8px;border-radius:50%;background:var(--text-muted);opacity:.3}
.source-header .filename{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--text-muted);letter-spacing:.05em}
.source-body{padding:28px 32px;max-height:420px;overflow-y:auto}
.source-body::-webkit-scrollbar{width:6px}
.source-body::-webkit-scrollbar-track{background:var(--bg-glass);border-radius:3px}
.source-body::-webkit-scrollbar-thumb{background:var(--text-muted);border-radius:3px;opacity:.5}
.source-body::-webkit-scrollbar-thumb:hover{opacity:.8}
.source-h2{font-family:'Outfit',sans-serif;font-weight:600;font-size:1rem;color:var(--text-primary);margin-bottom:6px}
.source-label{font-family:'JetBrains Mono',monospace;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:8px;margin-top:24px}
.source-label:first-child{margin-top:0}
.source-p{font-size:.82rem;color:var(--text-body);line-height:1.65;margin-bottom:10px}
.ref{font-family:'JetBrains Mono',monospace;font-size:.72rem;color:var(--text-muted);background:var(--source-ref);padding:1px 5px;border-radius:3px}
.source-tier{padding:12px 16px;border-left:3px solid var(--accent);background:var(--bg-glass);border-radius:0 8px 8px 0;margin:10px 0;font-size:.82rem;color:var(--text-body);line-height:1.6}
.source-tier strong{color:var(--text-primary);font-weight:600}
.source-fade{position:relative}
.source-fade::after{content:'';position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(transparent,var(--doc-bg));pointer-events:none}
.source-note{text-align:center;padding:10px;font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--text-muted);letter-spacing:.08em;border-top:1px solid var(--doc-border)}
/* Audience drop-off annotations */
.dropoff{display:flex;align-items:center;gap:8px;margin:14px 0;padding:8px 12px;border-radius:6px;font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.06em;text-transform:uppercase}
.dropoff .dropoff-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.dropoff-exec{background:rgba(255,140,0,0.08);color:#e89020;border:1px solid rgba(255,140,0,0.15)}
.dropoff-exec .dropoff-dot{background:#e89020}
.dropoff-ic{background:rgba(100,160,255,0.08);color:#6496e8;border:1px solid rgba(100,160,255,0.15)}
.dropoff-ic .dropoff-dot{background:#6496e8}

/* ========== FORMAT SWITCHER ========== */
.format-switcher{max-width:860px;margin-top:40px}
.format-tabs{display:flex;gap:4px;background:var(--tab-inactive-bg);border-radius:12px 12px 0 0;padding:4px 4px 0 4px;border:1px solid var(--border-subtle);border-bottom:none}
.format-tab{flex:1;padding:12px 16px;border:none;background:none;cursor:pointer;font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:var(--tab-inactive-text);border-radius:8px 8px 0 0;transition:all .3s}
.format-tab.active{background:var(--doc-bg);color:var(--text-primary);font-weight:500}
.format-tab:hover:not(.active){color:var(--text-primary)}
.format-panel{display:none;border:1px solid var(--border-subtle);border-top:none;border-radius:0 0 12px 12px;background:var(--doc-bg);box-shadow:var(--shadow-card);overflow:hidden}
.format-panel.active{display:block;animation:panelIn .4s ease}

/* ========== TWO-COLUMN TEASER LAYOUT ========== */
.teaser-layout{display:grid;grid-template-columns:65% 30%;gap:5%;padding:32px 36px;align-items:start}
.teaser-copy h3{font-family:'DM Serif Display',serif;font-size:1.35rem;color:var(--text-primary);line-height:1.3;margin-bottom:20px}
[data-theme="rainbow"] .teaser-copy h3{background:linear-gradient(135deg,#ff2d78,#ff6b35,#ffd600,#00e87b,#00c2ff,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.teaser-copy .tc-desc{font-size:.84rem;color:var(--text-muted);line-height:1.65;font-weight:300;margin-bottom:10px}
.teaser-copy .tc-desc:last-of-type{margin-bottom:24px}
.teaser-cta{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:.78rem;letter-spacing:.06em;color:var(--accent);text-decoration:none;padding:12px 28px;border:1px solid var(--accent);border-radius:8px;transition:all .3s;background:var(--accent-dim)}
.teaser-cta:hover{background:var(--accent);color:#fff}

/* Teaser sidebar: spec card */
.spec-card{margin-bottom:16px}
.spec-item{padding:6px 0;font-size:.78rem;line-height:1.5}
.spec-item:not(:last-child){border-bottom:1px solid var(--border-subtle)}
.spec-label{font-family:'JetBrains Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);display:block;margin-bottom:6px}
.spec-value{color:var(--text-body);display:block}

/* ========== ARTIFACT MINIATURES ========== */
.artifact-mini{border-radius:8px;overflow:hidden;border:1px solid var(--border-subtle);box-shadow:var(--shadow-card);aspect-ratio:4/3;position:relative}

/* -- Tech Reference Mini -- */
.mini-tech{background:#FAFAF7;padding:12px 14px;display:flex;flex-direction:column;gap:6px}
.mini-tech .mt-header{height:6px;width:55%;background:#1A8A8A;border-radius:2px;opacity:.3;margin-bottom:4px}
.mini-tech .mt-tier{height:18px;border-radius:0 3px 3px 0;background:rgba(0,0,0,0.03);border-left:2px solid #ccc;padding-left:6px;display:flex;align-items:center}
.mini-tech .mt-tier .mt-line{height:3px;border-radius:1px;background:rgba(0,0,0,0.12)}
.mini-tech .mt-tier.t1{border-left-color:#C4652A}
.mini-tech .mt-tier.t1 .mt-line{width:80%}
.mini-tech .mt-tier.t2{border-left-color:#B08D3E}
.mini-tech .mt-tier.t2 .mt-line{width:70%}
.mini-tech .mt-tier.t3{border-left-color:#1A8A8A}
.mini-tech .mt-tier.t3 .mt-line{width:60%}
.mini-tech .mt-tier.t4{border-left-color:#A69882}
.mini-tech .mt-tier.t4 .mt-line{width:45%}
.mini-tech .mt-action{height:2px;width:40%;background:#1A8A8A;border-radius:1px;opacity:.25;margin:2px 0 2px 8px}
.mini-tech .mt-sep{height:1px;background:rgba(0,0,0,0.06);margin:4px 0}
.mini-tech .mt-cat-row{display:flex;gap:4px;align-items:center}
.mini-tech .mt-badge{display:inline-block;height:8px;width:24px;border-radius:2px;opacity:.5}
.mini-tech .mt-badge.ba{background:rgba(196,101,42,0.2)}
.mini-tech .mt-badge.bb{background:rgba(176,141,62,0.2)}
.mini-tech .mt-cat-line{height:3px;flex:1;border-radius:1px;background:rgba(0,0,0,0.08)}

/* -- Exec Narrative Mini -- */
.mini-exec{background:#0A1628;padding:0;display:flex;flex-direction:column}
.mini-exec .me-section{flex:1;padding:8px 12px;display:flex;flex-direction:column;justify-content:center;position:relative}
.mini-exec .me-section:not(:last-child){border-bottom:1px solid rgba(255,255,255,0.04)}
.mini-exec .me-hero{background:radial-gradient(ellipse at 70% 40%,rgba(0,177,171,0.1),transparent)}
.mini-exec .me-kicker{height:2px;width:28px;background:#00B1AB;border-radius:1px;margin-bottom:4px;opacity:.6}
.mini-exec .me-headline{height:4px;width:70%;background:rgba(255,255,255,0.7);border-radius:1px;margin-bottom:3px}
.mini-exec .me-headline.short{width:45%}
.mini-exec .me-body{height:2px;width:55%;background:rgba(255,255,255,0.15);border-radius:1px;margin-bottom:2px}
.mini-exec .me-stats{display:flex;gap:4px;margin-top:3px}
.mini-exec .me-stat{flex:1;height:16px;border-radius:3px;background:rgba(15,32,57,0.8);border:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center}
.mini-exec .me-stat-num{height:5px;width:14px;background:#00B1AB;border-radius:1px;opacity:.7}
.mini-exec .me-tiers{display:grid;grid-template-columns:1fr 1fr;gap:3px;margin-top:3px}
.mini-exec .me-tier{height:14px;border-radius:2px;background:rgba(15,32,57,0.8);border:1px solid rgba(255,255,255,0.06);border-left:2px solid #00B1AB}
.mini-exec .me-tier.high{border-left-color:#EC0C6D}
.mini-exec .me-tier.mid{border-left-color:#F6A41A}
.mini-exec .me-dots{position:absolute;right:6px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:3px}
.mini-exec .me-dot{width:3px;height:3px;border-radius:50%;background:rgba(255,255,255,0.12)}
.mini-exec .me-dot.active{background:#00B1AB}

/* -- Training Deck Mini -- */
.mini-deck{background:#0A1628;padding:0;display:flex;flex-direction:column}
.mini-deck .md-viewport{flex:1;display:flex;overflow:hidden;position:relative}
.mini-deck .md-slide{min-width:100%;padding:8px 12px;display:flex;flex-direction:column;justify-content:center}
.mini-deck .md-kicker{height:2px;width:24px;background:#00B1AB;border-radius:1px;margin-bottom:4px;opacity:.6}
.mini-deck .md-headline{height:4px;width:65%;background:rgba(255,255,255,0.7);border-radius:1px;margin-bottom:3px}
.mini-deck .md-body{height:2px;width:50%;background:rgba(255,255,255,0.15);border-radius:1px;margin-bottom:6px}
.mini-deck .md-cards{display:grid;grid-template-columns:1fr 1fr;gap:3px}
.mini-deck .md-card{height:14px;border-radius:2px;background:rgba(15,32,57,0.8);border:1px solid rgba(255,255,255,0.06);border-left:2px solid #EC0C6D}
.mini-deck .md-card:nth-child(2){border-left-color:#F6A41A}
.mini-deck .md-card:nth-child(3){border-left-color:#00B1AB}
.mini-deck .md-card:nth-child(4){border-left-color:#8B9DB0}
.mini-deck .md-nav{display:flex;align-items:center;justify-content:center;gap:3px;padding:6px 0;border-top:1px solid rgba(255,255,255,0.04)}
.mini-deck .md-dot{width:4px;height:4px;border-radius:50%;background:rgba(255,255,255,0.12)}
.mini-deck .md-dot.active{background:#00B1AB;box-shadow:0 0 3px rgba(0,177,171,0.4)}
.mini-deck .md-arrow{width:8px;height:8px;border-radius:50%;border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;margin:0 3px}
.mini-deck .md-arrow-inner{width:0;height:0;border-top:2px solid transparent;border-bottom:2px solid transparent;border-left:3px solid rgba(255,255,255,0.2)}
.mini-deck .md-arrow.prev .md-arrow-inner{border-left:none;border-right:3px solid rgba(255,255,255,0.2)}

/* ========== TAKEAWAY ========== */
.takeaway-text{font-family:'Outfit',sans-serif;font-size:clamp(.95rem,1.5vw,1.05rem);font-weight:300;color:var(--text-body);line-height:1.7;max-width:640px;margin-top:24px}
.footer-meta{margin-top:48px;font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.1em;color:var(--text-muted)}
.footer-meta a.footer-link{color:var(--accent);text-decoration:none}.footer-meta a.footer-link:hover{text-decoration:underline}

/* Light mode: pink section 03 */
[data-theme="light"] section[data-index="3"]{background-color:rgba(194,48,98,0.75);background-image:linear-gradient(rgba(255,255,255,0.08) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.08) 1px,transparent 1px);background-size:32px 32px}
[data-theme="light"] section[data-index="3"] .section-num{color:rgba(255,255,255,0.9)}
[data-theme="light"] section[data-index="3"] .section-title{color:#1a1520}
[data-theme="light"] section[data-index="3"] .section-title em{color:rgba(255,255,255,0.9)}
