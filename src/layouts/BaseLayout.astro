---
interface Props {
  title: string;
  description?: string;
  skipTarget?: string;
  defaultTheme?: 'dark' | 'light' | 'rainbow';
}

const {
  title,
  description = 'Mae Mendoza — Senior Content Specialist & Subject Matter Expert',
  skipTarget = '#main-content',
  defaultTheme = 'light',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme={defaultTheme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:inline>
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      z-index: 99999;
      padding: 8px 16px;
      background: #c23062;
      color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      text-decoration: none;
      border-radius: 0 0 8px 8px;
    }
    .skip-link:focus {
      top: 0;
    }
  </style>
</head>
<body>
  <a href={skipTarget} class="skip-link">Skip to content</a>
  <slot />
  <script is:inline>
    // Restore saved theme from localStorage
    (function() {
      const saved = localStorage.getItem('mae-theme');
      if (saved && ['dark', 'light', 'rainbow'].includes(saved)) {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</body>
</html>
