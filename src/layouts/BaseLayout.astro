---
interface Props {
  title: string;
  description?: string;
  skipTarget?: string;
  defaultTheme?: 'dark' | 'light' | 'rainbow';
}

const {
  title,
  description = 'Mae Mendoza — Content Design & Subject Matter Expertise',
  skipTarget = '#main-content',
  defaultTheme = 'light',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme={defaultTheme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:inline>
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      z-index: 99999;
      padding: 8px 16px;
      background: #c23062;
      color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      text-decoration: none;
      border-radius: 0 0 8px 8px;
    }
    .skip-link:focus {
      top: 0;
    }

    /* =============================================
       PILL LINK — shared button system
       Shape and transition live here. Color and
       hover behavior are set per-theme below.
       Add class="pill-link" to any <a> element.
       Wrap visible text in <span class="pill-link-text">
       to get gradient text in rainbow mode.
       ============================================= */
    .pill-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 30px;
      border: 2px solid transparent;
      width: fit-content;
      text-decoration: none;
      transition: background 0.3s, color 0.3s, border-color 0.3s;
    }

    /* Light: solid accent border, white bg, invert on hover */
    [data-theme="light"] .pill-link {
      background: #ffffff;
      border-color: #c23062;
      color: #c23062;
    }
    [data-theme="light"] .pill-link:hover {
      background: #c23062;
      color: #ffffff;
    }
    [data-theme="light"] .pill-link:hover svg { stroke: #ffffff; }

    /* Dark: transparent bg, accent border per element,
       hover fills with accent. Color overrides are
       set per-component since accents vary. */
    [data-theme="dark"] .pill-link {
      background: transparent;
      border-color: rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.6);
    }
    [data-theme="dark"] .pill-link:hover {
      border-color: rgba(255,255,255,0.5);
      color: #ffffff;
      background: rgba(255,255,255,0.06);
    }
    [data-theme="dark"] .pill-link:hover svg { stroke: #ffffff; }

    /* Rainbow: gradient border at rest via padding-box/border-box
       background layering. Gradient fill on hover, black text.
       pill-link-text gets gradient text on the span. */
    [data-theme="rainbow"] .pill-link {
      background:
        linear-gradient(#000000, #000000) padding-box,
        linear-gradient(to right, #ff2d78, #f4845f, #f6c744, #00ffd5, #c4b5fd) border-box;
      color: #ffffff;
    }
    [data-theme="rainbow"] .pill-link:hover {
      background:
        linear-gradient(to right, #ff2d78, #f4845f, #f6c744, #00ffd5, #c4b5fd) padding-box,
        linear-gradient(to right, #ff2d78, #f4845f, #f6c744, #00ffd5, #c4b5fd) border-box;
      color: #000000;
    }
    [data-theme="rainbow"] .pill-link:hover svg { stroke: #000000; }
    [data-theme="rainbow"] .pill-link:hover .pill-link-text {
      background: none;
      -webkit-background-clip: unset;
      background-clip: unset;
      -webkit-text-fill-color: #000000;
      color: #000000;
    }

    /* Gradient text for rainbow rest state */
    [data-theme="rainbow"] .pill-link-text {
      background: linear-gradient(to right, #ff2d78, #f4845f, #f6c744, #00ffd5, #c4b5fd);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  </style>
</head>
<body>
  <a href={skipTarget} class="skip-link">Skip to content</a>
  <slot />
  <script is:inline>
    // Restore saved theme from localStorage
    (function() {
      const saved = localStorage.getItem('mae-theme');
      if (saved && ['dark', 'light', 'rainbow'].includes(saved)) {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</body>
</html>
