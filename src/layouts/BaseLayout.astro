---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  ogType?: string;
  skipTarget?: string;
  defaultTheme?: 'dark' | 'light' | 'rainbow';
}

const siteUrl = 'https://maemendoza.com';

const {
  title,
  description = 'Content design, UX writing, and subject matter expertise for digital products. More than 10 years across product, publishing, and platforms.',
  ogImage = '/OGpreview.png',
  canonicalPath,
  ogType = 'website',
  skipTarget = '#main-content',
  defaultTheme = 'light',
} = Astro.props;

const canonicalUrl = canonicalPath ? `${siteUrl}${canonicalPath}` : siteUrl;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en" data-theme={defaultTheme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Mae Mendoza" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <style is:inline>
    .skip-link {
      position: absolute;
      top: -100px;
      left: 16px;
      z-index: 99999;
      padding: 8px 16px;
      background: #c23062;
      color: #fff;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem;
      text-decoration: none;
      border-radius: 0 0 8px 8px;
    }
    .skip-link:focus {
      top: 0;
    }
  </style>
</head>
<body>
  <a href={skipTarget} class="skip-link">Skip to content</a>
  <slot />
  <script is:inline>
    // Restore saved theme from localStorage
    (function() {
      const saved = localStorage.getItem('mae-theme');
      if (saved && ['dark', 'light', 'rainbow'].includes(saved)) {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</body>
</html>
