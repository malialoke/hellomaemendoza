---
interface Props {
  title: string;
  description?: string;
  skipTarget?: string;
  defaultTheme?: 'dark' | 'light' | 'rainbow';
}

const {
  title,
  description = 'Mae Mendoza — Content Design & Subject Matter Expertise',
  skipTarget = '#main-content',
  defaultTheme = 'light',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme={defaultTheme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <a href={skipTarget} class="skip-link">Skip to content</a>
  <slot />
  <script is:inline>
    // Restore saved theme from localStorage
    (function() {
      const saved = localStorage.getItem('mae-theme');
      if (saved && ['dark', 'light', 'rainbow'].includes(saved)) {
        document.documentElement.setAttribute('data-theme', saved);
      }
    })();
  </script>
</body>
</html>
